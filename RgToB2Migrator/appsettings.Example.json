{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "RgToB2Migrator": "Information"
    }
  },
  "Supabase": {
    "Url": "https://<project-ref>.supabase.co",
    "ServiceKey": "<supabase-service-role-key>"
  },
  "Rapidgator": {
    "Username": "<rapidgator-email>",
    "Password": "<rapidgator-password>",
    "ApiBaseUrl": "https://rapidgator.net/api/v2",
    "RequestDelayMs": 3000
  },
  "B2": {
    "ApplicationKeyId": "<b2-application-key-id>",
    "ApplicationKey": "<b2-application-key>",
    "BucketName": "<b2-bucket-name>",
    "Region": "us-east-005",
    "ServiceUrl": "https://s3.us-east-005.backblazeb2.com"
  },
  "Migrator": {
    "TempFolder": "/tmp/rg-migrator",
    "RateLimitDelayMs": 3000
  }
}
