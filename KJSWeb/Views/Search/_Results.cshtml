@model KJSWeb.Models.SearchResultsViewModel
@using System.Text.Encodings.Web
@using System.Text.RegularExpressions
@{
    string Highlight(string text, string query)
    {
        if (string.IsNullOrEmpty(text) || string.IsNullOrEmpty(query))
            return HtmlEncoder.Default.Encode(text ?? "");
        var escaped = HtmlEncoder.Default.Encode(text);
        var pattern = Regex.Escape(HtmlEncoder.Default.Encode(query.Trim()));
        return Regex.Replace(escaped, pattern,
            m => $"<mark class=\"bg-orange-accent/20 text-orange-accent font-black not-italic rounded-sm px-0.5\">{m.Value}</mark>",
            RegexOptions.IgnoreCase);
    }
}

@if (string.IsNullOrWhiteSpace(Model.Query) || Model.Query.Trim().Length < 2)
{
    <div class="px-2 py-8 text-center text-slate-400 text-sm font-semibold">
        Type at least 2 characters to search…
    </div>
}
else if (!Model.Posts.Any())
{
    <div class="bg-white dark:bg-gray-800 rounded-sm px-6 py-10 text-center">
        <p class="text-2xl mb-3">🔍</p>
        <p class="text-slate-700 dark:text-gray-300 font-bold">No results for <span class="text-orange-accent">@Model.Query</span></p>
        <p class="text-slate-400 dark:text-gray-500 text-sm mt-1">Try a different keyword.</p>
    </div>
}
else
{
    <div class="bg-white dark:bg-gray-800 rounded-sm overflow-hidden shadow-2xl divide-y divide-slate-50 dark:divide-gray-700">
        <div class="px-5 py-3 flex items-center justify-between bg-slate-50 dark:bg-gray-700 border-b border-slate-100 dark:border-gray-600">
            <span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 dark:text-gray-400">@Model.Posts.Count result@(Model.Posts.Count != 1 ? "s" : "") for "@Model.Query"</span>
        </div>
        @foreach (var post in Model.Posts)
        {
            var ctrl   = post.SourceNameRaw == "AsianScandal" ? "AsianScandal" : "Home";
            var action = "Details";
            <a asp-controller="@ctrl" asp-action="@action" asp-route-id="@post.Id"
               class="flex items-center gap-4 px-5 py-4 hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors duration-150 group block">
                <!-- Thumbnail -->
                <div class="shrink-0 w-20 h-14 rounded-sm overflow-hidden bg-slate-100 dark:bg-gray-700">
                    @if (!string.IsNullOrEmpty(post.ThumbnailUrl))
                    {
                        <img src="@post.ThumbnailUrl" alt="@post.Title"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                    }
                </div>
                <!-- Info -->
                <div class="min-w-0 flex-1">
                    <p class="text-sm font-bold leading-tight line-clamp-2 group-hover:text-orange-accent transition-colors">
                        @Html.Raw(Highlight(post.Title, Model.Query))
                    </p>
                    <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">
                            @post.CreatedAt.ToString("MMM dd, yyyy")
                        </span>
                        <span class="w-1 h-1 rounded-full bg-slate-300 shrink-0"></span>
                        <span class="text-[9px] font-black uppercase tracking-widest px-1.5 py-0.5 rounded-sm
                                     @(post.SourceNameRaw == "AsianScandal" ? "bg-slate-900 text-white" : "bg-orange-accent text-white")">
                            @(post.SourceNameRaw == "AsianScandal" ? "Asian Scandal" : "Buzz69")
                        </span>
                        @if (post.Categories != null && post.Categories.Any())
                        {
                            <span class="w-1 h-1 rounded-full bg-slate-300 shrink-0"></span>
                            <span class="text-[10px] text-slate-400 font-semibold truncate">@post.Categories.First()</span>
                        }
                    </div>
                </div>
                <!-- Arrow -->
                <svg class="w-4 h-4 text-slate-200 group-hover:text-orange-accent transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        }
    </div>
}
