<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"]?.ToString().Contains("SCANDAL69") == true ? ViewData["Title"] : $"{ViewData["Title"]} - SCANDAL69")</title>
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/images/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="~/images/android-chrome-512x512.png" />
    @{
        var _canonicalUrl = ViewData["CanonicalUrl"] as string
            ?? $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
        var _ogTitle  = ViewData["OgTitle"] as string ?? "SCANDAL69";
        var _ogDesc   = ViewData["Description"] as string
            ?? "Premium content delivery network specializing in high-quality updates and community curation.";
        var _ogImage  = ViewData["OgImage"] as string ?? "";
        var _ogType   = ViewData["OgType"] as string ?? "website";
    }
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="description" content="@_ogDesc" />
    <link rel="canonical" href="@_canonicalUrl" />
    <meta property="og:site_name" content="SCANDAL69" />
    <meta property="og:type"        content="@_ogType" />
    <meta property="og:title"       content="@_ogTitle" />
    <meta property="og:description" content="@_ogDesc" />
    @if (!string.IsNullOrEmpty(_ogImage)) { <meta property="og:image" content="@_ogImage" /> }
    <meta property="og:url"         content="@_canonicalUrl" />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@_ogTitle" />
    <meta name="twitter:description" content="@_ogDesc" />
    @if (!string.IsNullOrEmpty(_ogImage)) { <meta name="twitter:image" content="@_ogImage" /> }
    @await RenderSectionAsync("Schema", required: false)
    <script>
      (function(){
        var theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'orange-accent': '#FF4500',
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #fcfcfc;
        }
        html.dark body {
            background-color: #111827; /* gray-900 */
        }
        .dropdown:hover .dropdown-menu {
            display: block;
            animation: fadeIn 0.2s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .content-card:hover .thumbnail-overlay {
            opacity: 1 !important;
        }
        .content-card:hover img {
            transform: scale(1.05);
        }
        .orange-accent {
            background-color: #FF4500;
        }
        .text-orange-accent {
            color: #FF4500;
        }
        .hover\:bg-orange-accent:hover {
            background-color: #FF4500;
        }
        .border-orange-accent {
            border-color: #FF4500;
        }
        .bg-orange-accent {
            background-color: #FF4500;
        }
        /* Custom scrollbar */
        .custom-scrollbar {
            max-height: 80vh;
            overflow-y: auto;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #444;
            border-radius: 10px;
        }

        /* Mobile: hide/show */
        .mobile-toggle { display: none; }
        .mobile-nav { display: none; }
        .mobile-nav.active { display: block; }
        .mobile-dropdown { display: none; }
        .mobile-dropdown.active { display: block; }

        @@media (max-width: 768px) {
            .desktop-nav { display: none !important; }
            .mobile-toggle { display: flex !important; }
            .mobile-toggle span {
                display: block;
                width: 24px;
                height: 2px;
                background: #fff;
                transition: all 0.3s;
            }
            .mobile-toggle.active span:nth-child(1) {
                transform: rotate(45deg) translate(4px, 5px);
            }
            .mobile-toggle.active span:nth-child(2) {
                opacity: 0;
            }
            .mobile-toggle.active span:nth-child(3) {
                transform: rotate(-45deg) translate(4px, -5px);
            }
        }
    </style>
</head>
<body class="text-slate-900 dark:bg-gray-900 dark:text-gray-100">

    <!-- Header / Navigation (Static, non-sticky) -->
    <header class="bg-black text-white py-6">
        <div class="container mx-auto px-4">
            <!-- Tier 1: Logo -->
            <div class="flex justify-center mb-6 relative">
                <div class="cursor-pointer">
                    <a asp-controller="Home" asp-action="Index" class="text-3xl sm:text-5xl font-black tracking-tighter text-white hover:text-white">SCANDAL69</a>
                </div>
                <!-- Mobile hamburger -->
                <button id="mobileToggle" class="mobile-toggle absolute right-0 top-1/2 -translate-y-1/2 flex-col gap-[5px] p-2 bg-transparent border-0 cursor-pointer" aria-label="Menu">
                    <span></span><span></span><span></span>
                </button>
            </div>

            <!-- Tier 2: Desktop Navigation Links — HIDDEN on mobile via CSS -->
            <nav class="desktop-nav flex flex-wrap justify-center items-center space-x-6 sm:space-x-10 text-[13px] font-bold uppercase tracking-widest">
                <a asp-controller="Home" asp-action="Index" class="hover:text-orange-accent transition-colors">Home</a>
                <a asp-controller="Home" asp-action="Buzz69" class="hover:text-orange-accent transition-colors">Buzz69</a>
                <a asp-controller="AsianScandal" asp-action="Index" class="hover:text-orange-accent transition-colors">Asian Scandal</a>
                <a asp-controller="JGirl" asp-action="Index" class="hover:text-orange-accent transition-colors">JGirl</a>

                <a asp-controller="Subscription" asp-action="Pricing" class="hover:text-orange-accent transition-colors">Upgrade</a>

                <button id="searchOpen" aria-label="Search" class="hover:text-orange-accent transition-colors p-1 -m-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                    </svg>
                </button>

                @if (Context.Session.GetString("user_id") != null)
                {
                    <!-- Profile dropdown (desktop) -->
                    <div class="relative dropdown">
                        <button class="flex items-center gap-2 py-4 -my-4 hover:opacity-80 transition-opacity">
                            <div class="w-8 h-8 rounded-full bg-orange-accent flex items-center justify-center text-white text-[13px] font-black select-none">
                                @(Context.Session.GetString("user_email")?[0].ToString().ToUpper() ?? "U")
                            </div>
                            <span class="text-[10px]">▼</span>
                        </button>
                        <div class="dropdown-menu hidden absolute right-0 pt-4 w-56 z-50">
                            <div class="bg-[#121212] dark:bg-gray-900 border border-white/10 shadow-2xl">
                                <div class="px-4 py-3 border-b border-white/10">
                                    <p class="text-[10px] text-slate-400 uppercase tracking-widest">Signed in as</p>
                                    <p class="text-white text-xs font-bold truncate mt-0.5">@Context.Session.GetString("user_email")</p>
                                </div>
                                <div class="py-1">
                                    <a asp-controller="Subscription" asp-action="MySubscription"
                                       class="flex items-center gap-3 px-4 py-3 text-[12px] font-bold uppercase tracking-widest hover:bg-white/5 hover:text-orange-accent transition-colors">
                                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                                        My Subscription
                                    </a>
                                    <a asp-controller="Subscription" asp-action="Pricing"
                                       class="flex items-center gap-3 px-4 py-3 text-[12px] font-bold uppercase tracking-widest hover:bg-white/5 hover:text-orange-accent transition-colors">
                                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        Upgrade
                                    </a>
                                    <a asp-controller="Support" asp-action="Tickets"
                                       class="flex items-center gap-3 px-4 py-3 text-[12px] font-bold uppercase tracking-widest hover:bg-white/5 hover:text-orange-accent transition-colors">
                                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" /></svg>
                                        My Tickets
                                    </a>
                                </div>
                                <div class="border-t border-white/10 py-1">
                                    <form method="post" asp-controller="Auth" asp-action="Logout">
                                        <button type="submit" class="flex items-center gap-3 w-full px-4 py-3 text-[12px] font-bold uppercase tracking-widest hover:bg-white/5 hover:text-orange-accent transition-colors text-left">
                                            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                                            Logout
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" class="hover:text-orange-accent transition-colors">Login</a>
                    <a asp-controller="Auth" asp-action="Signup" class="hover:text-orange-accent transition-colors">Sign Up</a>
                }
            </nav>

            <!-- Mobile Navigation — ONLY visible when toggled on mobile -->
            <nav class="mobile-nav" id="mobileNav">
                <div class="mt-4 border-t border-white/10 pt-4 space-y-0">
                    <a asp-controller="Home" asp-action="Index" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5">Home</a>
                    <a asp-controller="Home" asp-action="Buzz69" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5">Buzz69</a>
                    <a asp-controller="AsianScandal" asp-action="Index" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5 text-orange-accent italic">Asian Scandal ✨</a>
                    <a asp-controller="JGirl" asp-action="Index" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5">JGirl</a>
                    <a asp-controller="Subscription" asp-action="Pricing" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5">Upgrade</a>
                    @if (Context.Session.GetString("user_id") != null)
                    {
                        <div class="flex items-center gap-3 py-3 border-b border-white/5">
                            <div class="w-8 h-8 rounded-full bg-orange-accent flex items-center justify-center text-white text-[13px] font-black shrink-0">
                                @(Context.Session.GetString("user_email")?[0].ToString().ToUpper() ?? "U")
                            </div>
                            <span class="text-slate-400 text-[11px] truncate">@Context.Session.GetString("user_email")</span>
                        </div>
                        <a asp-controller="Subscription" asp-action="MySubscription" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5 pl-4">My Subscription</a>
                        <a asp-controller="Support" asp-action="Tickets" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5 pl-4">My Tickets</a>
                        <form method="post" asp-controller="Auth" asp-action="Logout">
                            <button type="submit" class="block w-full text-left py-3 pl-4 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-b border-white/5">Login</a>
                        <a asp-controller="Auth" asp-action="Signup" class="block py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors">Sign Up</a>
                    }
                    <!-- Mobile search -->
                    <button id="searchOpenMobile" class="flex items-center gap-3 w-full py-3 text-[13px] font-bold uppercase tracking-widest hover:text-orange-accent transition-colors border-t border-white/5 mt-1 pt-4">
                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                        </svg>
                        Search
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <main role="main" class="container mx-auto px-4 py-6 sm:py-12 dark:bg-gray-900">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-black text-slate-500 py-16 mt-20 border-t border-white/5 dark:bg-gray-900 dark:border-gray-800">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12 text-center md:text-left">
                <div class="col-span-1 md:col-span-2">
                    <a asp-controller="Home" asp-action="Index" class="text-3xl font-black tracking-tighter text-white mb-6 block hover:text-white">SCANDAL69</a>
                    <p class="text-xs leading-relaxed max-w-sm mx-auto md:mx-0">Premium content delivery network specializing in high-quality updates and community curation. Est 2026.</p>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6 uppercase text-[10px] tracking-[0.3em]">Network</h4>
                    <ul class="space-y-3 text-[11px] font-bold uppercase tracking-wider">
                        <li><a href="#" class="hover:text-orange-accent transition-colors">Privacy</a></li>
                        <li><a href="#" class="hover:text-orange-accent transition-colors">Terms</a></li>
                        <li><a href="#" class="hover:text-orange-accent transition-colors">2257</a></li>
                        <li><a href="#" class="hover:text-orange-accent transition-colors">DMCA</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6 uppercase text-[10px] tracking-[0.3em]">Support</h4>
                    <ul class="space-y-3 text-[11px] font-bold uppercase tracking-wider">
                        <li><a href="#" class="hover:text-orange-accent transition-colors">Help</a></li>
                        <li><a href="#" class="hover:text-orange-accent transition-colors">Contact</a></li>
                        <li><a href="#" class="hover:text-orange-accent transition-colors">Ads</a></li>
                        <li><a href="#" class="hover:text-orange-accent transition-colors">Affiliates</a></li>
                    </ul>
                </div>
            </div>
            <div class="mt-16 pt-8 border-t border-white/5 text-center text-[9px] uppercase tracking-[0.4em]">
                &copy; @DateTime.Now.Year SCANDAL69. Strictly 18+.
            </div>
        </div>
    </footer>

    <!-- Search overlay -->
    <div id="search-overlay"
         class="fixed inset-0 z-[100] flex flex-col items-start justify-start pt-20 px-4
                bg-black/80 backdrop-blur-sm
                opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out">
        <!-- Backdrop click to close -->
        <div id="searchBackdrop" class="absolute inset-0"></div>

        <!-- Panel -->
        <div id="searchPanel"
             class="relative w-full max-w-2xl mx-auto z-10
                    translate-y-4 transition-transform duration-300 ease-out">

            <!-- Input bar -->
            <div class="flex items-center bg-white dark:bg-gray-800 shadow-2xl px-5 py-4 gap-3 rounded-sm">
                <svg class="w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                </svg>
                <input id="searchInput" type="text" name="q" placeholder="Search posts…" autocomplete="off"
                       class="flex-1 text-lg font-semibold outline-none placeholder-slate-300 bg-transparent dark:text-gray-100 dark:placeholder-gray-500"
                       hx-get="/search/results"
                       hx-trigger="input delay:300ms, keyup[key=='Enter']"
                       hx-target="#search-results"
                       hx-swap="innerHTML" />
                <button id="searchClose" class="text-slate-300 hover:text-black transition-colors duration-150 shrink-0 p-1 -m-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <!-- Results -->
            <div id="search-results" class="mt-2 max-h-[60vh] overflow-y-auto rounded-sm"></div>
        </div>
    </div>

    <!-- Dark mode toggle — fixed bottom-left -->
    <button id="theme-toggle" aria-label="Toggle dark mode"
            style="position:fixed;bottom:20px;left:20px;z-index:9999;"
            class="w-11 h-11 flex items-center justify-center rounded-full bg-gray-900 dark:bg-white border border-white/20 dark:border-gray-300 shadow-xl hover:scale-110 transition-transform">
        <!-- Sun icon (shown in dark mode) — Heroicons outline -->
        <svg id="icon-sun" class="hidden w-5 h-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <!-- Moon icon (shown in light mode) — Heroicons outline -->
        <svg id="icon-moon" class="w-5 h-5 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
    </button>

    <script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
