@model List<KJSWeb.Models.Post>
@{
    var period       = ViewBag.PopularPeriod as string ?? "week";
    var sourcePrefix = ViewBag.SourcePrefix  as string ?? "";
}

<!-- Period toggle -->
<div class="flex mb-5 border border-slate-200 rounded-sm overflow-hidden">
    @foreach (var p in new[] { "week", "month", "year" })
    {
        var active = period == p;
        <button hx-get="/@sourcePrefix/popular?period=@p"
                hx-target="#popular-widget"
                hx-swap="innerHTML"
                class="flex-1 text-center text-[10px] font-black uppercase tracking-wider py-2 transition-colors cursor-pointer border-0
                       @(active ? "bg-black text-white" : "bg-transparent text-slate-500 hover:bg-slate-100")">
            @p
        </button>
    }
</div>

<!-- Popular post list -->
@if (Model != null && Model.Any())
{
    <div class="space-y-5">
        @for (int i = 0; i < Model.Count; i++)
        {
            var post = Model[i];
            var ctrl = post.SourceNameRaw == "AsianScandal" ? "AsianScandal" : "Home";
            <div class="flex gap-3 items-start">
                <span class="text-xl font-black text-slate-200 leading-none w-5 shrink-0 mt-1">@(i + 1)</span>
                <a asp-controller="@ctrl" asp-action="Details" asp-route-id="@post.Id" class="shrink-0">
                    <img src="@post.ThumbnailUrl" alt="@post.Title"
                         class="w-20 h-14 object-cover rounded-sm" loading="lazy" />
                </a>
                <div class="min-w-0">
                    <a asp-controller="@ctrl" asp-action="Details" asp-route-id="@post.Id"
                       class="text-xs font-bold leading-tight line-clamp-2 hover:text-orange-accent transition-colors block">
                        @post.Title
                    </a>
                    <span class="flex items-center gap-1 text-[10px] text-slate-400 font-bold mt-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        @post.ViewCount.ToString("N0")
                    </span>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-slate-400 text-xs">No posts this @period.</p>
}
