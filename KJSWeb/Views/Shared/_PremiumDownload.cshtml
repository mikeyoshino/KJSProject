@model KJSWeb.Models.DownloadComponentModel
@{
    var downloadUrls = Model.DownloadUrls ?? new List<string>();
    var dlCount = downloadUrls.Count;
    var isSubscribed = Model.IsSubscribed;
    var publicUrls = Model.PublicDownloadUrls;
    var hasPublic = publicUrls != null && publicUrls.Any();
}

<style>
    .glass-card {
        background: rgba(17, 24, 39, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .premium-glow {
        position: relative;
    }
    .premium-glow::before {
        content: "";
        position: absolute;
        inset: -2px;
        background: linear-gradient(45deg, #FF4500, #ff8c00, #FF4500);
        border-radius: inherit;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.3s ease;
        filter: blur(8px);
    }
    .premium-glow:hover::before {
        opacity: 0.6;
    }
</style>

<div class="mt-12 mb-8">
    @if (isSubscribed)
    {
        <!-- SUBSCRIBER VIEW: Only show the Direct Premium Download -->
        <div class="glass-card rounded-2xl p-8 border-l-4 border-l-orange-accent shadow-2xl relative overflow-hidden">
            <!-- Decorative gradient -->
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-orange-accent/20 rounded-full blur-3xl pointer-events-none"></div>
            
            <div class="flex items-center gap-4 mb-6 relative z-10">
                <div class="w-12 h-12 rounded-full bg-orange-accent/10 flex items-center justify-center text-orange-accent">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <div>
                    <h3 class="text-2xl font-black text-slate-900 dark:text-white m-0 tracking-tight">Premium Download Ready</h3>
                    <p class="text-sm font-semibold text-green-500 mt-1 uppercase tracking-wider">Instant • Full Speed • No Ads</p>
                </div>
            </div>

            @if (downloadUrls.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 relative z-10">
                    @for (int i = 0; i < downloadUrls.Count; i++)
                    {
                        <a href="@downloadUrls[i]" download class="premium-glow flex items-center justify-center gap-2 py-4 px-6 bg-slate-900 dark:bg-black text-white rounded-xl font-bold uppercase tracking-wider hover:-translate-y-1 transition-transform duration-300 border border-white/10 hover:border-orange-accent/50 group">
                            <svg class="w-5 h-5 group-hover:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            @(dlCount > 1 ? $"Download Part {i + 1}" : "Download File")
                        </a>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <!-- NON-SUBSCRIBER VIEW: Side by side comparison if free is available -->
        <h3 class="text-sm font-black text-slate-500 uppercase tracking-widest text-center mb-6">Choose Download Method</h3>
        
        <div class="grid grid-cols-1 @(hasPublic ? "md:grid-cols-2" : "") gap-6 max-w-5xl mx-auto">
            
            @if (hasPublic)
            {
                <!-- FREE DOWNLOAD CARD -->
                <div class="bg-white dark:bg-gray-800/80 rounded-2xl p-6 md:p-8 border border-gray-200 dark:border-gray-700 shadow-lg flex flex-col items-center text-center transition-transform hover:-translate-y-1 duration-300">
                    <div class="w-16 h-16 rounded-2xl bg-gray-100 dark:bg-gray-700/50 flex items-center justify-center text-gray-500 mb-6">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    
                    <h4 class="text-xl font-black text-slate-800 dark:text-gray-200 mb-2">Free Download</h4>
                    <p class="text-sm text-slate-500 dark:text-gray-400 mb-6 flex-grow">
                        Basic file access supported by our advertising partners.
                    </p>

                    <ul class="w-full text-left space-y-3 mb-8">
                        <li class="flex items-center gap-3 text-sm font-medium text-slate-600 dark:text-gray-300">
                            <span class="text-red-500">⚠</span> Wait time required
                        </li>
                        <li class="flex items-center gap-3 text-sm font-medium text-slate-600 dark:text-gray-300">
                            <span class="text-red-500">⚠</span> Third-party advertisements
                        </li>
                        <li class="flex items-center gap-3 text-sm font-medium text-slate-600 dark:text-gray-300">
                            <span class="text-orange-400">⚡</span> Speed capped at 5 MB/s
                        </li>
                    </ul>

                    <div class="w-full space-y-3">
                        @for (int i = 0; i < publicUrls!.Count; i++)
                        {
                            <a href="@publicUrls[i]" target="_blank" rel="noopener" class="block w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-slate-700 dark:text-gray-200 font-bold uppercase tracking-wider text-sm rounded-xl transition-colors">
                                @(publicUrls.Count > 1 ? $"Free Download — Part {i + 1}" : "Free Download")
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- PREMIUM UPGRADE CARD -->
            <div class="premium-glow relative bg-gradient-to-br from-slate-900 to-black rounded-2xl p-6 md:p-8 border border-white/10 shadow-2xl flex flex-col items-center text-center overflow-hidden transition-transform hover:-translate-y-1 duration-300">
                <!-- Decorative gradient inside -->
                <div class="absolute inset-0 bg-gradient-to-t from-orange-accent/10 to-transparent pointer-events-none"></div>

                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-orange-400 to-orange-accent flex items-center justify-center text-white mb-6 relative z-10 shadow-lg shadow-orange-accent/30">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                
                <h4 class="text-xl font-black text-white mb-2 relative z-10">Premium Download</h4>
                <p class="text-sm text-gray-400 mb-6 flex-grow relative z-10">
                    Skip the ads and wait times. Instant access for subscribers.
                </p>

                <ul class="w-full text-left space-y-3 mb-8 relative z-10">
                    <li class="flex items-center gap-3 text-sm font-bold text-white">
                        <span class="text-green-400">✓</span> Instant, 0 sec wait time
                    </li>
                    <li class="flex items-center gap-3 text-sm font-bold text-white">
                        <span class="text-green-400">✓</span> Completely Ad-Free
                    </li>
                    <li class="flex items-center gap-3 text-sm font-bold text-white">
                        <span class="text-green-400">✓</span> Unlimited max speed
                    </li>
                </ul>

                <a asp-controller="Subscription" asp-action="Pricing" class="w-full py-4 px-4 bg-orange-accent hover:bg-orange-600 text-white font-black uppercase tracking-widest text-sm rounded-xl transition-colors relative z-10 shadow-lg shadow-orange-accent/20">
                    Unlock Premium Now
                </a>
            </div>
            
        </div>
    }
</div>
