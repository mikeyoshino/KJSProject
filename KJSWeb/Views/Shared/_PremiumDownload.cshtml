@model KJSWeb.Models.DownloadComponentModel
@{
    var downloadUrls = Model.DownloadUrls ?? new List<string>();
    var dlCount = downloadUrls.Count;
    var isSubscribed = Model.IsSubscribed;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Archivo:wght@500;700;900&display=swap');

    .premium-download {
        --accent: #FF4500;
        --dark: #0F0F0F;
        --light: #FAFAFA;
        --border: rgba(255, 69, 0, 0.2);
        font-family: 'Archivo', sans-serif;
    }

    .premium-download__container {
        position: relative;
        margin-top: 4rem;
        overflow: hidden;
    }

    /* ─── LOCKED STATE (Premium/Subscription Required) ─── */
    .premium-download--locked {
        background: linear-gradient(135deg, var(--dark) 0%, #1a1a1a 100%);
        border: 2px solid var(--border);
        padding: 3rem 2rem;
        border-radius: 2px;
    }

    .premium-download--locked::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle at 100% 0%, rgba(255, 69, 0, 0.08) 0%, transparent 70%);
        pointer-events: none;
    }

    .premium-download--locked::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
            45deg,
            transparent 0%,
            rgba(255, 255, 255, 0.02) 50%,
            transparent 100%
        );
        pointer-events: none;
    }

    .premium-download__content {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .premium-download__icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
        animation: float-icon 3s ease-in-out infinite;
        display: block;
    }

    @@keyframes float-icon {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-12px); }
    }

    .premium-download__title {
        font-family: 'Space Mono', monospace;
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        margin-top: 0;
    }

    .premium-download__subtitle {
        font-size: 0.875rem;
        color: #999;
        margin-bottom: 2rem;
        font-weight: 500;
        line-height: 1.6;
        max-width: 420px;
        margin-left: auto;
        margin-right: auto;
    }

    .premium-download__cta {
        display: inline-block;
        background: var(--accent);
        color: white;
        padding: 1rem 2.5rem;
        font-family: 'Space Mono', monospace;
        font-weight: 700;
        font-size: 0.875rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        text-decoration: none;
    }

    .premium-download__cta::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.2);
        transition: left 0.3s ease;
    }

    .premium-download__cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(255, 69, 0, 0.3);
    }

    .premium-download__cta:hover::before {
        left: 100%;
    }

    /* ─── UNLOCKED STATE (Downloads Available) ─── */
    .premium-download--unlocked {
        background: white;
        border: 1px solid #E5E5E5;
        padding: 2.5rem 2rem;
    }

    html.dark .premium-download--unlocked {
        background: #1f2937;
        border-color: #374151;
    }

    html.dark .premium-download--unlocked .premium-download__title {
        color: #f3f4f6;
    }

    html.dark .premium-download--unlocked .premium-download__header {
        border-bottom-color: #374151;
    }

    .premium-download--unlocked::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent) 0%, transparent 100%);
    }

    .premium-download--unlocked .premium-download__header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #F0F0F0;
    }

    .premium-download--unlocked .premium-download__icon {
        font-size: 2rem;
        animation: none;
        flex-shrink: 0;
        margin-bottom: 0;
    }

    .premium-download--unlocked .premium-download__title {
        color: var(--dark);
        font-size: 1.25rem;
        margin: 0;
        text-align: left;
    }

    .premium-download__links {
        display: grid;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    @@media (min-width: 640px) {
        .premium-download__links {
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        }
    }

    .premium-download__link {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.25rem 1.5rem;
        background: var(--dark);
        color: white;
        font-weight: 700;
        font-size: 0.875rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all 0.25s ease;
        border-radius: 2px;
    }

    .premium-download__link:hover {
        background: var(--accent);
        border-color: var(--accent);
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(255, 69, 0, 0.2);
    }

    .premium-download__link-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .premium-download__link-text {
        font-size: 0.8125rem;
    }

    /* ─── RESPONSIVE ─── */
    @@media (max-width: 640px) {
        .premium-download--locked {
            padding: 2rem 1.5rem;
        }

        .premium-download--unlocked {
            padding: 1.5rem;
        }

        .premium-download__title {
            font-size: 1.125rem;
        }

        .premium-download__icon {
            font-size: 3rem;
        }

        .premium-download__links {
            gap: 0.75rem;
        }

        .premium-download__link {
            padding: 1rem 1.25rem;
            font-size: 0.8125rem;
        }
    }
</style>

@if (isSubscribed)
{
    <!-- UNLOCKED STATE -->
    <div class="premium-download premium-download--unlocked premium-download__container">
        <div class="premium-download__header">
            <span class="premium-download__icon">⚡</span>
            <h3 class="premium-download__title">Download Ready</h3>
        </div>

        @if (downloadUrls.Any())
        {
            <div class="premium-download__links">
                @for (int i = 0; i < downloadUrls.Count; i++)
                {
                    <a href="@downloadUrls[i]" class="premium-download__link" download>
                        <svg class="premium-download__link-icon" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                        </svg>
                        <span class="premium-download__link-text">
                            @(dlCount > 1 ? $"Part {i + 1}" : "Download")
                        </span>
                    </a>
                }
            </div>
        }
    </div>
}
else
{
    <!-- LOCKED STATE -->
    <div class="premium-download premium-download--locked premium-download__container">
        <div class="premium-download__content">
            <span class="premium-download__icon">🔐</span>
            <h3 class="premium-download__title">Premium Access Required</h3>
            <p class="premium-download__subtitle">
                Subscribe now to unlock instant downloads, HD quality, and priority support.
                Gain access to @Model.DownloadCount download link(s) for this exclusive content.
            </p>
            <a asp-controller="Subscription" asp-action="Pricing" class="premium-download__cta">
                ✨ Upgrade to Premium
            </a>
        </div>
    </div>
}
