@model List<KJSWeb.Models.Subscription>
@{
    ViewData["Title"] = "Subscriptions";
    Layout = "~/Views/Crm/_Layout.cshtml";
    var pagination   = ViewBag.Pagination   as KJSWeb.Models.PaginationInfo;
    var activeStatus = ViewBag.ActiveStatus as string ?? "";
    var statuses     = new[] { ("", "All"), ("active", "Active"), ("pending", "Pending"),
                               ("expired", "Expired"), ("revoked", "Revoked"), ("confirming", "Confirming") };
}

<div class="mb-8 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-black text-slate-900 dark:text-gray-100">Subscriptions</h1>
        <p class="text-slate-500 dark:text-gray-400 text-sm mt-1">All plans &amp; payments</p>
    </div>
</div>

<!-- Status filter tabs -->
<div class="flex gap-1 mb-6 bg-white dark:bg-gray-800 rounded-xl border border-slate-100 dark:border-gray-700 shadow-sm p-1.5 w-fit">
    @foreach (var (val, label) in statuses)
    {
        var isActive = activeStatus == val;
        var href = string.IsNullOrEmpty(val) ? "/crm/subscriptions" : $"/crm/subscriptions?status={val}";
        <a href="@href"
           class="px-4 py-1.5 text-xs font-black uppercase tracking-wider rounded-lg transition-colors @(isActive ? "bg-slate-900 text-white" : "text-slate-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-gray-100 hover:bg-slate-50 dark:hover:bg-gray-700")">
            @label
        </a>
    }
</div>

<!-- Table -->
<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-slate-100 dark:border-gray-700">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-100 dark:border-gray-700">
                    <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">User</th>
                    <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Plan</th>
                    <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Status</th>
                    <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Paid At</th>
                    <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Expires At</th>
                    <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Amount</th>
                    <th class="px-5 py-3 text-center text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50 dark:divide-gray-700">
                @foreach (var s in Model)
                {
                    <tr class="hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors">
                        <td class="px-5 py-3">
                            <a href="/crm/users/@s.UserId" class="text-slate-700 dark:text-gray-300 font-medium hover:text-orange-accent transition-colors truncate max-w-[180px] block">
                                @(string.IsNullOrEmpty(s.Email) ? s.UserId[..8] + "…" : s.Email)
                            </a>
                        </td>
                        <td class="px-5 py-3 capitalize text-slate-600 dark:text-gray-400">@s.Plan</td>
                        <td class="px-5 py-3">@StatusBadge(s.Status)</td>
                        <td class="px-5 py-3 text-slate-500 dark:text-gray-400 text-xs">@(s.PaidAt?.ToString("MMM dd, yyyy") ?? "—")</td>
                        <td class="px-5 py-3 text-slate-500 dark:text-gray-400 text-xs">@(s.ExpiresAt?.ToString("MMM dd, yyyy") ?? "—")</td>
                        <td class="px-5 py-3 text-right font-mono text-slate-600 dark:text-gray-400">$@s.AmountUsd.ToString("N2")</td>
                        <td class="px-5 py-3">
                            <div class="flex gap-3 justify-center">
                                @if (s.Status == "active")
                                {
                                    <form method="post" action="/crm/subscriptions/@s.Id/revoke" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="text-[10px] font-black uppercase tracking-wider text-red-500 hover:text-red-700 transition-colors"
                                                onclick="return confirm('Revoke this subscription?')">
                                            Revoke
                                        </button>
                                    </form>
                                    <button onclick="openExtend('@s.Id')"
                                            class="text-[10px] font-black uppercase tracking-wider text-blue-500 hover:text-blue-700 transition-colors">
                                        Extend
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="px-5 py-12 text-center text-slate-400 dark:text-gray-500">No subscriptions found</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (pagination != null && pagination.TotalPages > 1)
    {
        <div class="px-5 py-4 border-t border-slate-100 dark:border-gray-700 flex items-center justify-between">
            <span class="text-xs text-slate-400 dark:text-gray-500">
                Showing @((pagination.CurrentPage - 1) * pagination.PageSize + 1)–@Math.Min(pagination.CurrentPage * pagination.PageSize, pagination.TotalItems) of @pagination.TotalItems
            </span>
            <div class="flex gap-2">
                @if (pagination.CurrentPage > 1)
                {
                    var prev = string.IsNullOrEmpty(activeStatus)
                        ? $"/crm/subscriptions?page={pagination.CurrentPage - 1}"
                        : $"/crm/subscriptions?status={activeStatus}&page={pagination.CurrentPage - 1}";
                    <a href="@prev" class="px-3 py-1.5 text-xs font-bold border border-slate-200 dark:border-gray-600 dark:text-gray-300 rounded hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors">← Prev</a>
                }
                @if (pagination.CurrentPage < pagination.TotalPages)
                {
                    var next = string.IsNullOrEmpty(activeStatus)
                        ? $"/crm/subscriptions?page={pagination.CurrentPage + 1}"
                        : $"/crm/subscriptions?status={activeStatus}&page={pagination.CurrentPage + 1}";
                    <a href="@next" class="px-3 py-1.5 text-xs font-bold border border-slate-200 dark:border-gray-600 dark:text-gray-300 rounded hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors">Next →</a>
                }
            </div>
        </div>
    }
</div>

<!-- Extend modal -->
<div id="extend-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-sm p-6">
        <h3 class="text-lg font-black text-slate-900 dark:text-gray-100 mb-4">Extend Subscription</h3>
        <form id="extend-form" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="block text-xs font-bold text-slate-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Days to add</label>
                <input type="number" name="days" min="1" max="3650" value="30" required
                       class="w-full border border-slate-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent" />
            </div>
            <div class="flex gap-3">
                <button type="submit" class="flex-1 bg-slate-900 text-white py-2.5 text-sm font-bold rounded-lg hover:bg-orange-accent transition-colors">
                    Extend
                </button>
                <button type="button" onclick="document.getElementById('extend-modal').classList.add('hidden')"
                        class="flex-1 bg-slate-100 dark:bg-gray-700 text-slate-700 dark:text-gray-300 py-2.5 text-sm font-bold rounded-lg hover:bg-slate-200 dark:hover:bg-gray-600 transition-colors">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

@functions {
    static Microsoft.AspNetCore.Html.IHtmlContent StatusBadge(string status)
    {
        var (bg, text) = status switch
        {
            "active"     => ("bg-green-100 text-green-700",  "Active"),
            "pending"    => ("bg-yellow-100 text-yellow-700","Pending"),
            "confirming" => ("bg-blue-100 text-blue-700",    "Confirming"),
            "expired"    => ("bg-slate-100 text-slate-500",  "Expired"),
            "revoked"    => ("bg-red-100 text-red-600",      "Revoked"),
            _            => ("bg-slate-100 text-slate-500",  status)
        };
        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<span class=\"inline-block px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider {bg}\">{text}</span>");
    }
}

@section Scripts {
<script>
function openExtend(subId) {
    document.getElementById('extend-form').action = '/crm/subscriptions/' + subId + '/extend';
    document.getElementById('extend-modal').classList.remove('hidden');
}
</script>
}
