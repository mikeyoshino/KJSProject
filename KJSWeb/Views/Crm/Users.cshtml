@using KJSWeb.Controllers
@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Crm/_Layout.cshtml";
    var query   = ViewBag.Query   as string ?? "";
    var results = ViewBag.Results as List<UserSearchResult> ?? new();
}

<div class="mb-8">
    <h1 class="text-2xl font-black text-slate-900 dark:text-gray-100">Users</h1>
    <p class="text-slate-500 dark:text-gray-400 text-sm mt-1">Search by email address</p>
</div>

<!-- Search form -->
<form method="get" action="/crm/users/search" class="mb-8">
    <div class="flex gap-3 max-w-xl">
        <input type="text" name="q" value="@query"
               placeholder="Search by email…"
               class="flex-1 border border-slate-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent focus:border-transparent"
               autofocus />
        <button type="submit"
                class="bg-slate-900 text-white px-6 py-2.5 text-sm font-bold rounded-lg hover:bg-orange-accent transition-colors">
            Search
        </button>
    </div>
</form>

<!-- Results -->
@if (!string.IsNullOrEmpty(query))
{
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-slate-100 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-gray-700">
            <h2 class="text-sm font-black uppercase tracking-wider text-slate-700 dark:text-gray-300">
                Results for "@query" — @results.Count found
            </h2>
        </div>

        @if (results.Any())
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-100 dark:border-gray-700">
                        <th class="px-6 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Email</th>
                        <th class="px-6 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Registered</th>
                        <th class="px-6 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Last Sign-in</th>
                        <th class="px-6 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Subscription</th>
                        <th class="px-6 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400 dark:text-gray-500">Status</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 dark:divide-gray-700">
                    @foreach (var r in results)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors">
                            <td class="px-6 py-3 font-medium text-slate-800 dark:text-gray-100">@r.User.Email</td>
                            <td class="px-6 py-3 text-slate-500 dark:text-gray-400 text-xs">@r.User.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="px-6 py-3 text-slate-500 dark:text-gray-400 text-xs">@(r.User.LastSignInAt?.ToString("MMM dd, yyyy") ?? "Never")</td>
                            <td class="px-6 py-3 text-slate-600 dark:text-gray-400 text-xs">@r.SubStatus</td>
                            <td class="px-6 py-3">
                                @if (r.IsBanned)
                                {
                                    <span class="inline-block px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider bg-red-100 text-red-600">Banned</span>
                                }
                                else
                                {
                                    <span class="inline-block px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider bg-green-100 text-green-700">OK</span>
                                }
                            </td>
                            <td class="px-6 py-3 text-right">
                                <a href="/crm/users/@r.User.Id"
                                   class="text-[11px] font-bold text-orange-accent hover:underline uppercase tracking-wider">
                                    Manage →
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="px-6 py-12 text-center text-slate-400 dark:text-gray-500">No users found matching "@query"</div>
        }
    </div>
}
