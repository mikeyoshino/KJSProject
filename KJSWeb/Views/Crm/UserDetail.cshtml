@using KJSWeb.Services
@using KJSWeb.Models
@{
    ViewData["Title"] = "User Detail";
    Layout = "~/Views/Crm/_Layout.cshtml";
    var user      = ViewBag.User      as AdminUser         ?? new AdminUser();
    var activeSub = ViewBag.ActiveSub as Subscription;
    var history   = ViewBag.History   as List<Subscription> ?? new();
    var isBanned  = (bool)(ViewBag.IsBanned ?? false);
    var tickets   = ViewBag.Tickets   as List<SupportTicket> ?? new();
}

<!-- Breadcrumb -->
<div class="mb-6 text-sm text-slate-400">
    <a href="/crm/users" class="hover:text-orange-accent transition-colors">Users</a>
    <span class="mx-2">/</span>
    <span class="text-slate-700 font-medium">@user.Email</span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Left column -->
    <div class="flex flex-col gap-6">

        <!-- User info card -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <div class="flex items-center gap-4 mb-5">
                <div class="w-12 h-12 rounded-full bg-slate-200 flex items-center justify-center text-lg font-black text-slate-600">
                    @(user.Email.Length > 0 ? user.Email[0].ToString().ToUpperInvariant() : "?")
                </div>
                <div>
                    <div class="font-bold text-slate-900">@user.Email</div>
                    @if (isBanned)
                    {
                        <span class="inline-block mt-1 px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider bg-red-100 text-red-600">Banned</span>
                    }
                    else
                    {
                        <span class="inline-block mt-1 px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider bg-green-100 text-green-700">Active</span>
                    }
                </div>
            </div>
            <dl class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <dt class="text-slate-400">User ID</dt>
                    <dd class="text-slate-600 font-mono text-xs truncate max-w-[120px]" title="@user.Id">@user.Id[..8]…</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-slate-400">Registered</dt>
                    <dd class="text-slate-700">@user.CreatedAt.ToString("MMM dd, yyyy")</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-slate-400">Last sign-in</dt>
                    <dd class="text-slate-700">@(user.LastSignInAt?.ToString("MMM dd, yyyy") ?? "Never")</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-slate-400">Subscription</dt>
                    <dd class="text-slate-700">
                        @if (activeSub != null)
                        {
                            <span class="text-green-600 font-semibold">Active — @activeSub.Plan</span>
                        }
                        else
                        {
                            <span class="text-slate-400">None</span>
                        }
                    </dd>
                </div>
                @if (activeSub != null)
                {
                    <div class="flex justify-between">
                        <dt class="text-slate-400">Expires</dt>
                        <dd class="text-slate-700">@activeSub.ExpiresAt?.ToString("MMM dd, yyyy")</dd>
                    </div>
                }
            </dl>
        </div>

        <!-- Ban/Unban card -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h3 class="text-sm font-black uppercase tracking-wider text-slate-700 mb-4">Account Control</h3>
            @if (isBanned)
            {
                <form method="post" action="/crm/users/@user.Id/unban">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full bg-green-600 text-white py-2.5 text-sm font-bold rounded-lg hover:bg-green-700 transition-colors">
                        Unban User
                    </button>
                </form>
            }
            else
            {
                <button onclick="document.getElementById('ban-modal').classList.remove('hidden')"
                        class="w-full bg-red-600 text-white py-2.5 text-sm font-bold rounded-lg hover:bg-red-700 transition-colors">
                    Ban User
                </button>
            }
        </div>

        <!-- Grant subscription card -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h3 class="text-sm font-black uppercase tracking-wider text-slate-700 mb-4">Grant Subscription</h3>
            <form method="post" action="/crm/subscriptions/grant" class="space-y-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@user.Id" />
                <input type="hidden" name="email"  value="@user.Email" />
                <div>
                    <label class="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Plan</label>
                    <select name="plan"
                            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent">
                        <option value="monthly">Monthly (30 days)</option>
                        <option value="3month">3-Month (90 days)</option>
                        <option value="yearly">Yearly (365 days)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Custom Days <span class="normal-case font-normal text-slate-400">(optional override)</span></label>
                    <input type="number" name="customDays" min="1" max="3650" placeholder="e.g. 45"
                           class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent" />
                </div>
                <button type="submit"
                        class="w-full bg-slate-900 text-white py-2.5 text-sm font-bold rounded-lg hover:bg-orange-accent transition-colors">
                    Grant Subscription
                </button>
            </form>
        </div>

    </div>

    <!-- Right column — subscription history + tickets -->
    <div class="lg:col-span-2 flex flex-col gap-8">
        <div class="bg-white rounded-xl shadow-sm border border-slate-100">
            <div class="px-6 py-4 border-b border-slate-100">
                <h2 class="text-sm font-black uppercase tracking-wider text-slate-700">Subscription History</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-100">
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Plan</th>
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Status</th>
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Paid At</th>
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Expires At</th>
                            <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-wider text-slate-400">Amount</th>
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">TXID</th>
                            <th class="px-5 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var s in history)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-5 py-3 capitalize text-slate-700 font-medium">@s.Plan</td>
                                <td class="px-5 py-3">@StatusBadge(s.Status)</td>
                                <td class="px-5 py-3 text-slate-500 text-xs">@(s.PaidAt?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td class="px-5 py-3 text-slate-500 text-xs">@(s.ExpiresAt?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td class="px-5 py-3 text-right font-mono text-slate-600">$@s.AmountUsd.ToString("N2")</td>
                                <td class="px-5 py-3 font-mono text-slate-400 text-xs">
                                    @if (!string.IsNullOrEmpty(s.Txid))
                                    {
                                        <span title="@s.Txid">@s.Txid[..Math.Min(8, s.Txid.Length)]…</span>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td class="px-5 py-3">
                                    <div class="flex gap-2 justify-end">
                                        @if (s.Status == "active")
                                        {
                                            <form method="post" action="/crm/subscriptions/@s.Id/revoke" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="returnUserId" value="@user.Id" />
                                                <button type="submit"
                                                        class="text-[10px] font-black uppercase tracking-wider text-red-500 hover:text-red-700 transition-colors"
                                                        onclick="return confirm('Revoke this subscription?')">
                                                    Revoke
                                                </button>
                                            </form>

                                            <button onclick="openExtend('@s.Id', '@user.Id')"
                                                    class="text-[10px] font-black uppercase tracking-wider text-blue-500 hover:text-blue-700 transition-colors">
                                                Extend
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!history.Any())
                        {
                            <tr><td colspan="7" class="px-5 py-10 text-center text-slate-400">No subscription history</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tickets -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                <h2 class="text-sm font-black uppercase tracking-wider text-slate-700">Support Tickets</h2>
                <a href="/crm/tickets" class="text-[10px] font-black uppercase tracking-wider text-slate-400 hover:text-orange-accent transition-colors">View All</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-100">
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Title</th>
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Status</th>
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Created</th>
                            <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-wider text-slate-400">Last Reply</th>
                            <th class="px-5 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var t in tickets)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-5 py-3 text-slate-700 font-medium max-w-[240px] truncate" title="@t.Title">@t.Title</td>
                                <td class="px-5 py-3">@TicketStatusBadge(t.StatusRaw)</td>
                                <td class="px-5 py-3 text-slate-500 text-xs">@t.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-5 py-3 text-slate-500 text-xs">@(t.LastReplyAt?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td class="px-5 py-3 text-right">
                                    <a href="/crm/tickets/@t.Id"
                                       class="text-[10px] font-black uppercase tracking-wider text-blue-500 hover:text-blue-700 transition-colors">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!tickets.Any())
                        {
                            <tr><td colspan="5" class="px-5 py-10 text-center text-slate-400">No tickets from this user</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

</div>

<!-- Ban modal -->
<div id="ban-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md p-6">
        <h3 class="text-lg font-black text-slate-900 mb-1">Ban @user.Email?</h3>
        <p class="text-slate-400 text-sm mb-5">They will be immediately signed out and blocked from logging in.</p>
        <form method="post" action="/crm/users/@user.Id/ban">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Reason <span class="normal-case font-normal text-slate-400">(optional)</span></label>
                <textarea name="reason" rows="3" placeholder="e.g. Chargeback fraud"
                          class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"></textarea>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="flex-1 bg-red-600 text-white py-2.5 text-sm font-bold rounded-lg hover:bg-red-700 transition-colors">
                    Confirm Ban
                </button>
                <button type="button" onclick="document.getElementById('ban-modal').classList.add('hidden')"
                        class="flex-1 bg-slate-100 text-slate-700 py-2.5 text-sm font-bold rounded-lg hover:bg-slate-200 transition-colors">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Extend modal -->
<div id="extend-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-sm p-6">
        <h3 class="text-lg font-black text-slate-900 mb-4">Extend Subscription</h3>
        <form id="extend-form" method="post">
            @Html.AntiForgeryToken()
            <input id="extend-return-user" type="hidden" name="returnUserId" value="" />
            <div class="mb-4">
                <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Days to add</label>
                <input type="number" name="days" min="1" max="3650" value="30" required
                       class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent" />
            </div>
            <div class="flex gap-3">
                <button type="submit" class="flex-1 bg-slate-900 text-white py-2.5 text-sm font-bold rounded-lg hover:bg-orange-accent transition-colors">
                    Extend
                </button>
                <button type="button" onclick="document.getElementById('extend-modal').classList.add('hidden')"
                        class="flex-1 bg-slate-100 text-slate-700 py-2.5 text-sm font-bold rounded-lg hover:bg-slate-200 transition-colors">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

@functions {
    static Microsoft.AspNetCore.Html.IHtmlContent StatusBadge(string status)
    {
        var (bg, text) = status switch
        {
            "active"     => ("bg-green-100 text-green-700",  "Active"),
            "pending"    => ("bg-yellow-100 text-yellow-700","Pending"),
            "confirming" => ("bg-blue-100 text-blue-700",    "Confirming"),
            "expired"    => ("bg-slate-100 text-slate-500",  "Expired"),
            "revoked"    => ("bg-red-100 text-red-600",      "Revoked"),
            _            => ("bg-slate-100 text-slate-500",  status)
        };
        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<span class=\"inline-block px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider {bg}\">{text}</span>");
    }

    static Microsoft.AspNetCore.Html.IHtmlContent TicketStatusBadge(string status)
    {
        var (bg, text) = status?.ToLower() switch
        {
            "open"        => ("bg-yellow-100 text-yellow-700", "Open"),
            "in_progress" => ("bg-blue-100 text-blue-700",     "In Progress"),
            "resolved"    => ("bg-green-100 text-green-700",   "Resolved"),
            _             => ("bg-slate-100 text-slate-500",   status ?? "Unknown")
        };
        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<span class=\"inline-block px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider {bg}\">{text}</span>");
    }
}

@section Scripts {
<script>
function openExtend(subId, userId) {
    document.getElementById('extend-form').action = '/crm/subscriptions/' + subId + '/extend';
    document.getElementById('extend-return-user').value = userId;
    document.getElementById('extend-modal').classList.remove('hidden');
}
</script>
}
