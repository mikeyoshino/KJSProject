@model List<KJSWeb.Models.JGirlPost>
@using System.Text.Json
@{
    ViewData["Title"] = "JGirl";
    var pagination   = ViewBag.Pagination    as KJSWeb.Models.PaginationInfo;
    var sources      = ViewBag.Sources       as List<string> ?? new();
    var activeSource = ViewBag.ActiveSource  as string;

    string PageUrl(int p) =>
        string.IsNullOrEmpty(activeSource)
            ? Url.Action("Index", "JGirl", new { page = p })!
            : Url.Action("Index", "JGirl", new { page = p, source = activeSource })!;
}

<div class="flex flex-col md:flex-row gap-10">

    <!-- Main content -->
    <div class="flex-1 min-w-0">

        <!-- Title bar -->
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-4">
            <h1 class="text-2xl font-bold text-slate-800 border-l-4 border-orange-accent pl-4 uppercase tracking-tight">
                @(string.IsNullOrEmpty(activeSource) ? "JGirl" : activeSource)
            </h1>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var post in Model)
            {
                var framesJson = JsonSerializer.Serialize(post.Images);
                <article class="group cursor-pointer" data-frames="@framesJson">
                    <a asp-controller="JGirl" asp-action="Details" asp-route-id="@post.Id">
                        <!-- Thumbnail with scrubber -->
                        <div class="relative overflow-hidden rounded-sm bg-slate-900 aspect-video mb-3 shadow-sm select-none">
                            <img class="scrubber-thumb w-full h-full object-cover transition-opacity duration-150"
                                 src="@post.ThumbnailUrl" alt="@post.Title" loading="lazy" draggable="false" />

                            <!-- Source badge -->
                            @if (!string.IsNullOrEmpty(post.Source))
                            {
                                <span class="absolute top-0 left-0 bg-slate-900/80 text-white text-[9px] font-black uppercase px-2 py-1 tracking-widest">@post.Source</span>
                            }

                            <!-- New badge -->
                            @if ((DateTime.UtcNow - post.CreatedAt).TotalHours < 48)
                            {
                                <span class="absolute top-0 right-0 bg-green-500 text-white text-[9px] font-black uppercase px-2 py-1 tracking-widest">New</span>
                            }

                            <!-- Frame counter (hidden until scrubbing) -->
                            <span class="scrubber-counter absolute bottom-6 right-2 bg-black/70 text-white text-[9px] font-black px-1.5 py-0.5 rounded opacity-0 transition-opacity duration-150 pointer-events-none tabular-nums"></span>

                            <!-- Scrubber bar -->
                            <div class="scrubber-bar absolute bottom-0 left-0 right-0 h-1.5 bg-white/20 cursor-pointer
                                        group-hover:h-2.5 transition-all duration-150"
                                 onclick="event.preventDefault()">
                                <div class="scrubber-fill h-full bg-orange-accent w-0 transition-none pointer-events-none"></div>
                                <div class="scrubber-knob absolute top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-orange-accent -ml-1.5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="left:0"></div>
                            </div>
                        </div>
                    </a>

                    <!-- Card info -->
                    <div class="space-y-1 px-0.5">
                        <h2 class="text-sm font-bold leading-tight group-hover:text-orange-accent transition-colors line-clamp-2">
                            <a asp-controller="JGirl" asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                        </h2>
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                </article>
            }
        </div>

        <!-- Pagination -->
        @if (pagination != null && pagination.TotalPages > 1)
        {
            <div class="mt-20 flex justify-center items-center space-x-1 sm:space-x-2">
                @if (pagination.HasPrevious)
                {
                    <a href="@PageUrl(pagination.CurrentPage - 1)"
                       class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 text-slate-600 hover:bg-orange-accent hover:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                }
                @foreach (var pageNum in pagination.GetPageNumbers())
                {
                    if (pageNum == null)
                    {
                        <span class="px-2 text-slate-300 font-bold">…</span>
                    }
                    else if (pageNum == pagination.CurrentPage)
                    {
                        <span class="w-10 h-10 rounded flex items-center justify-center bg-orange-accent text-white font-bold text-sm">@pageNum</span>
                    }
                    else
                    {
                        <a href="@PageUrl(pageNum.Value)"
                           class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 text-slate-600 hover:bg-orange-accent hover:text-white transition-all font-bold text-sm">@pageNum</a>
                    }
                }
                @if (pagination.HasNext)
                {
                    <a href="@PageUrl(pagination.CurrentPage + 1)"
                       class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 text-slate-600 hover:bg-orange-accent hover:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                }
            </div>
        }
    </div>

    <!-- Sidebar -->
    @if (sources.Any())
    {
        <aside class="w-full md:w-56 lg:w-64 shrink-0">
            <div>
                <h4 class="text-[11px] font-black uppercase tracking-[0.3em] border-b-2 border-black pb-2 mb-4">Categories</h4>
                <ul>
                    <li>
                        <a href="/jgirl"
                           class="flex items-center justify-between py-2 text-sm font-semibold hover:text-orange-accent transition-colors border-b border-slate-100 @(string.IsNullOrEmpty(activeSource) ? "text-orange-accent" : "")">
                            <span>All</span>
                        </a>
                    </li>
                    @foreach (var src in sources)
                    {
                        <li>
                            <a href="/jgirl?source=@Uri.EscapeDataString(src)"
                               class="flex items-center justify-between py-2 text-sm font-semibold hover:text-orange-accent transition-colors border-b border-slate-100 @(activeSource == src ? "text-orange-accent" : "")">
                                <span class="truncate pr-2 capitalize">@src</span>
                                <svg class="w-3 h-3 text-slate-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </aside>
    }

</div>
