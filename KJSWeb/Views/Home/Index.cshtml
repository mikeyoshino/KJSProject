@* ── Upskirt Section ─────────────────────────────────────────────────── *@
<section class="mb-20">
    <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-black uppercase tracking-tighter border-l-4 border-orange-accent pl-4">Upskirt</h2>
        <a href="/jgirl?source=upskirt" class="text-[11px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">View All →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var post in upskirtPosts)
        {
            var framesJson = JsonSerializer.Serialize(post.Images);
            <article class="group cursor-pointer" data-frames="@framesJson">
                <a asp-controller="JGirl" asp-action="Details" asp-route-id="@post.Id">
                    <div class="relative overflow-hidden rounded-sm bg-slate-900 aspect-video mb-3 shadow-sm select-none">
                        <img class="scrubber-thumb w-full h-full object-cover"
                             src="@post.ThumbnailUrl" alt="@post.Title" loading="lazy" draggable="false" />
                        @if ((DateTime.UtcNow - post.CreatedAt).TotalHours < 48)
                        {
                            <span class="absolute top-0 right-0 bg-green-500 text-white text-[9px] font-black uppercase px-2 py-1 tracking-widest">New</span>
                        }
                        <span class="scrubber-counter absolute bottom-6 right-2 bg-black/70 text-white text-[9px] font-black px-1.5 py-0.5 rounded opacity-0 pointer-events-none tabular-nums"></span>
                        <div class="scrubber-bar absolute bottom-0 left-0 right-0 h-1.5 bg-white/20 cursor-pointer group-hover:h-2.5 transition-all duration-150" onclick="event.preventDefault()">
                            <div class="scrubber-fill h-full bg-orange-accent w-0 pointer-events-none"></div>
                            <div class="scrubber-knob absolute top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-orange-accent -ml-1.5 opacity-0 group-hover:opacity-100 pointer-events-none" style="left:0"></div>
                        </div>
                    </div>
                </a>
                <div class="space-y-1 px-0.5">
                    <h3 class="text-sm font-bold leading-tight group-hover:text-orange-accent transition-colors line-clamp-2">
                        <a asp-controller="JGirl" asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                    </h3>
                    <p class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">@post.CreatedAt.ToString("MMM dd, yyyy")</p>
                </div>
            </article>
        }
    </div>
</section>

