@model List<KJSWeb.Models.Post>
@using KJSWeb.Models
@{
    var sourceTitle        = ViewBag.SourceTitle   as string;
    var sourcePrefix       = ViewBag.SourcePrefix  as string;
    var categoryName       = ViewBag.CategoryName  as string;
    var pagination         = ViewBag.Pagination    as KJSWeb.Models.PaginationInfo;
    var showSidebar        = ViewBag.ShowSidebar   == true;
    var sidebarCategories  = ViewBag.SidebarCategories as List<KJSWeb.Models.Category> ?? new();
    var popularPosts       = ViewBag.PopularPosts  as List<KJSWeb.Models.Post>         ?? new();
    var period             = ViewBag.PopularPeriod as string ?? "week";

    var pageTitle = !string.IsNullOrEmpty(categoryName) ? categoryName
                  : !string.IsNullOrEmpty(sourceTitle)  ? sourceTitle + " Updates"
                  : "Latest Updates";
    ViewData["Title"] = pageTitle;

    string PageUrl(int p)
    {
        if (!string.IsNullOrEmpty(categoryName))
            return $"/category/{Uri.EscapeDataString(categoryName)}?page={p}";
        if (!string.IsNullOrEmpty(sourcePrefix))
            return $"/{sourcePrefix}?page={p}&period={period}";
        return Url.Action("Index", "Home", new { page = p })!;
    }
}

<div class="flex flex-col md:flex-row gap-10">

    <!-- Main Content -->
    <div class="flex-1 min-w-0">

        <!-- Title Bar -->
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-4">
            <h1 class="text-2xl font-bold text-slate-800 dark:text-gray-100 border-l-4 border-orange-accent pl-4 uppercase tracking-tight">
                @pageTitle
            </h1>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
            @foreach (var post in Model)
            {
                var ctrl = post.SourceNameRaw == "AsianScandal" ? "AsianScandal" : "Home";
                <article class="content-card group cursor-pointer">
                    <a asp-controller="@ctrl" asp-action="Details" asp-route-id="@post.Id">
                        <div class="relative overflow-hidden rounded-sm bg-slate-200 aspect-video mb-4 shadow-sm">
                            <img src="@post.ThumbnailUrl" alt="@post.Title"
                                 class="w-full h-full object-cover transition-transform duration-700" loading="lazy">
                            <div class="thumbnail-overlay opacity-0 absolute inset-0 bg-black/40 flex items-center justify-center transition-opacity duration-300">
                                <div class="w-14 h-14 rounded-full bg-orange-accent flex items-center justify-center shadow-lg transform scale-90 group-hover:scale-100 transition-transform">
                                    <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg>
                                </div>
                            </div>
                            @if (post.Categories != null && post.Categories.Any())
                            {
                                <span class="absolute top-0 left-0 bg-orange-accent text-white text-[9px] font-black uppercase px-2 py-1 tracking-widest">@post.Categories.First()</span>
                            }
                            @if ((DateTime.UtcNow - post.CreatedAt).TotalHours < 24)
                            {
                                <span class="absolute top-0 right-0 bg-green-500 text-white text-[9px] font-black uppercase px-2 py-1 tracking-widest">New</span>
                            }
                        </div>
                    </a>
                    <div class="space-y-1.5 text-center">
                        <h2 class="text-base font-bold leading-tight group-hover:text-orange-accent transition-colors">
                            <a asp-controller="@ctrl" asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                        </h2>
                        <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest">@post.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    </div>
                </article>
            }
        </div>

        <!-- Pagination -->
        @if (pagination != null && pagination.TotalPages > 1)
        {
            <div class="mt-20 flex justify-center items-center space-x-1 sm:space-x-2">
                @if (pagination.HasPrevious)
                {
                    <a href="@PageUrl(pagination.CurrentPage - 1)"
                       class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 dark:bg-gray-700 text-slate-600 dark:text-gray-300 hover:bg-orange-accent hover:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </a>
                }

                @foreach (var pageNum in pagination.GetPageNumbers())
                {
                    if (pageNum == null)
                    {
                        <span class="px-2 text-slate-300 dark:text-gray-600 font-bold">…</span>
                    }
                    else if (pageNum == pagination.CurrentPage)
                    {
                        <span class="w-10 h-10 rounded flex items-center justify-center bg-orange-accent text-white font-bold text-sm">@pageNum</span>
                    }
                    else
                    {
                        <a href="@PageUrl(pageNum.Value)"
                           class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 dark:bg-gray-700 text-slate-600 dark:text-gray-300 hover:bg-orange-accent hover:text-white transition-all font-bold text-sm">@pageNum</a>
                    }
                }

                @if (pagination.HasNext)
                {
                    <a href="@PageUrl(pagination.CurrentPage + 1)"
                       class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 dark:bg-gray-700 text-slate-600 dark:text-gray-300 hover:bg-orange-accent hover:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                }
            </div>
        }
    </div>

    <!-- Sidebar — only on source listing pages -->
    @if (showSidebar)
    {
        <aside class="w-full md:w-56 lg:w-64 shrink-0 space-y-10">

            <!-- Categories Widget -->
            @if (sidebarCategories.Any())
            {
                var previewCats = sidebarCategories.Take(6).ToList();
                <div>
                    <h4 class="text-[11px] font-black uppercase tracking-[0.3em] border-b-2 border-black dark:border-gray-600 pb-2 mb-4">@Localizer["Categories"]</h4>
                    <ul>
                        @foreach (var cat in previewCats)
                        {
                            <li>
                                <a href="/category/@Uri.EscapeDataString(cat.Name)"
                                   class="flex items-center justify-between py-2 text-sm font-semibold hover:text-orange-accent transition-colors border-b border-slate-100 dark:border-gray-700">
                                    <span class="truncate pr-2">@cat.Name</span>
                                    <svg class="w-3 h-3 text-slate-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                </a>
                            </li>
                        }
                    </ul>
                    @if (sidebarCategories.Count > 6)
                    {
                        <button onclick="document.getElementById('cat-modal').classList.remove('hidden')"
                                class="mt-3 text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-gray-500 hover:text-orange-accent transition-colors w-full text-left">
                            + @(sidebarCategories.Count - 6) more categories
                        </button>
                    }
                </div>

                <!-- Categories Modal -->
                <div id="cat-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
                    <!-- Backdrop -->
                    <div class="absolute inset-0 bg-black/60" onclick="document.getElementById('cat-modal').classList.add('hidden')"></div>
                    <!-- Panel -->
                    <div class="relative bg-white dark:bg-gray-800 w-full max-w-2xl max-h-[80vh] overflow-y-auto shadow-2xl rounded-sm">
                        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 dark:border-gray-700 sticky top-0 bg-white dark:bg-gray-800 z-10">
                            <h3 class="text-[11px] font-black uppercase tracking-[0.3em]">@Localizer["Categories"]</h3>
                            <button onclick="document.getElementById('cat-modal').classList.add('hidden')"
                                    class="text-slate-400 dark:text-gray-500 hover:text-black dark:hover:text-gray-100 transition-colors p-1">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                            </button>
                        </div>
                        <div class="p-6 grid grid-cols-2 sm:grid-cols-3 gap-2">
                            @foreach (var cat in sidebarCategories)
                            {
                                <a href="/category/@Uri.EscapeDataString(cat.Name)"
                                   onclick="document.getElementById('cat-modal').classList.add('hidden')"
                                   class="px-3 py-2 text-xs font-bold border border-slate-200 dark:border-gray-700 dark:text-gray-300 hover:border-orange-accent hover:text-orange-accent transition-colors truncate rounded-sm">
                                    @cat.Name
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Popular Posts Widget -->
            <div>
                <h4 class="text-[11px] font-black uppercase tracking-[0.3em] border-b-2 border-black dark:border-gray-600 pb-2 mb-4">@Localizer["Popular posts"]</h4>
                <div id="popular-widget">
                    @await Html.PartialAsync("_PopularPosts", popularPosts)
                </div>
            </div>

        </aside>
    }

</div>
