@model List<KJSWeb.Models.SupportTicket>
@using KJSWeb.Models
@{
    ViewData["Title"] = "My Support Tickets";
    var pagination = ViewBag.Pagination as PaginationInfo;

    string StatusBadgeClass(TicketStatus status) => status switch
    {
        TicketStatus.Open       => "bg-yellow-100 text-yellow-800",
        TicketStatus.InProgress => "bg-blue-100 text-blue-800",
        TicketStatus.Resolved   => "bg-green-100 text-green-800",
        _                       => "bg-slate-100 text-slate-600"
    };

    string StatusLabel(TicketStatus status) => status switch
    {
        TicketStatus.Open       => "Open",
        TicketStatus.InProgress => "In Progress",
        TicketStatus.Resolved   => "Resolved",
        _                       => status.ToString()
    };

    string PageUrl(int p) => Url.Action("Tickets", "Support", new { page = p })!;
}

<div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
        <h1 class="text-2xl font-bold text-slate-800 border-l-4 border-orange-accent pl-4 uppercase tracking-tight">
            My Support Tickets
        </h1>
        <button
            onclick="document.getElementById('new-ticket-modal').classList.remove('hidden')"
            class="inline-flex items-center gap-2 bg-orange-accent text-white px-5 py-2.5 text-[12px] font-bold uppercase tracking-wider hover:opacity-90 transition-opacity">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            New Ticket
        </button>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 text-sm font-medium">
            @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 text-green-700 text-sm font-medium">
            @TempData["Success"]
        </div>
    }

    <!-- Tickets Table -->
    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-20 bg-white border border-slate-200 rounded-sm">
            <svg class="w-12 h-12 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
            </svg>
            <p class="text-slate-400 font-semibold text-sm uppercase tracking-wider">No tickets yet</p>
            <p class="text-slate-400 text-xs mt-1">Open a new ticket to get help from our support team.</p>
        </div>
    }
    else
    {
        <div class="bg-white border border-slate-200 rounded-sm overflow-hidden">
            <!-- Desktop table -->
            <table class="w-full text-sm hidden sm:table">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="text-left text-[10px] font-black uppercase tracking-widest text-slate-500 px-5 py-3 w-24">#</th>
                        <th class="text-left text-[10px] font-black uppercase tracking-widest text-slate-500 px-5 py-3">Title</th>
                        <th class="text-left text-[10px] font-black uppercase tracking-widest text-slate-500 px-5 py-3 w-32">Status</th>
                        <th class="text-left text-[10px] font-black uppercase tracking-widest text-slate-500 px-5 py-3 w-36">Created</th>
                        <th class="text-left text-[10px] font-black uppercase tracking-widest text-slate-500 px-5 py-3 w-36">Last Reply</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var ticket in Model)
                    {
                        <tr class="hover:bg-slate-50 cursor-pointer transition-colors"
                            onclick="window.location='/support/tickets/@ticket.Id'">
                            <td class="px-5 py-4 font-mono text-[11px] text-slate-400">
                                @ticket.Id.Substring(0, Math.Min(8, ticket.Id.Length))…
                            </td>
                            <td class="px-5 py-4 font-semibold text-slate-800">
                                <a href="/support/tickets/@ticket.Id" class="hover:text-orange-accent transition-colors">
                                    @ticket.Title
                                </a>
                            </td>
                            <td class="px-5 py-4">
                                <span class="inline-block px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-wider @StatusBadgeClass(ticket.Status)">
                                    @StatusLabel(ticket.Status)
                                </span>
                            </td>
                            <td class="px-5 py-4 text-slate-500 text-xs">
                                @ticket.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td class="px-5 py-4 text-slate-500 text-xs">
                                @(ticket.LastReplyAt.HasValue
                                    ? ticket.LastReplyAt.Value.ToString("MMM dd, yyyy")
                                    : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Mobile cards -->
            <div class="sm:hidden divide-y divide-slate-100">
                @foreach (var ticket in Model)
                {
                    <a href="/support/tickets/@ticket.Id" class="block px-4 py-4 hover:bg-slate-50 transition-colors">
                        <div class="flex items-start justify-between gap-3 mb-1.5">
                            <span class="font-semibold text-slate-800 text-sm leading-snug flex-1">@ticket.Title</span>
                            <span class="shrink-0 inline-block px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-wider @StatusBadgeClass(ticket.Status)">
                                @StatusLabel(ticket.Status)
                            </span>
                        </div>
                        <div class="flex items-center gap-3 text-[11px] text-slate-400">
                            <span>@ticket.CreatedAt.ToString("MMM dd, yyyy")</span>
                            @if (ticket.LastReplyAt.HasValue)
                            {
                                <span>·</span>
                                <span>Reply: @ticket.LastReplyAt.Value.ToString("MMM dd, yyyy")</span>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>

        <!-- Pagination -->
        @if (pagination != null && pagination.TotalPages > 1)
        {
            <div class="mt-10 flex justify-center items-center space-x-1 sm:space-x-2">
                @if (pagination.HasPrevious)
                {
                    <a href="@PageUrl(pagination.CurrentPage - 1)"
                       class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 text-slate-600 hover:bg-orange-accent hover:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </a>
                }
                @foreach (var pageNum in pagination.GetPageNumbers())
                {
                    if (pageNum == null)
                    {
                        <span class="px-2 text-slate-300 font-bold">…</span>
                    }
                    else if (pageNum == pagination.CurrentPage)
                    {
                        <span class="w-10 h-10 rounded flex items-center justify-center bg-orange-accent text-white font-bold text-sm">@pageNum</span>
                    }
                    else
                    {
                        <a href="@PageUrl(pageNum.Value)"
                           class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 text-slate-600 hover:bg-orange-accent hover:text-white transition-all font-bold text-sm">@pageNum</a>
                    }
                }
                @if (pagination.HasNext)
                {
                    <a href="@PageUrl(pagination.CurrentPage + 1)"
                       class="w-10 h-10 rounded flex items-center justify-center bg-slate-200 text-slate-600 hover:bg-orange-accent hover:text-white transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                }
            </div>
        }
    }
</div>

<!-- New Ticket Modal -->
<div id="new-ticket-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/60" onclick="document.getElementById('new-ticket-modal').classList.add('hidden')"></div>
    <div class="relative bg-white w-full max-w-lg shadow-2xl rounded-sm">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <h3 class="text-[11px] font-black uppercase tracking-[0.3em]">Open New Ticket</h3>
            <button onclick="document.getElementById('new-ticket-modal').classList.add('hidden')"
                    class="text-slate-400 hover:text-black transition-colors p-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <form id="new-ticket-form" class="p-6 space-y-4">
            @Html.AntiForgeryToken()
            <div id="ticket-form-error" class="hidden p-3 bg-red-50 border-l-4 border-red-500 text-red-700 text-sm"></div>
            <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1.5">Title</label>
                <input type="text" name="title" required maxlength="200"
                       class="w-full border border-slate-200 px-3 py-2.5 text-sm focus:outline-none focus:border-orange-accent transition-colors"
                       placeholder="Brief description of your issue">
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1.5">Category</label>
                <select name="category"
                        class="w-full border border-slate-200 px-3 py-2.5 text-sm focus:outline-none focus:border-orange-accent transition-colors bg-white">
                    <option value="payment">Payment</option>
                    <option value="download">Download</option>
                    <option value="account">Account</option>
                    <option value="other" selected>Other</option>
                </select>
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1.5">Description</label>
                <textarea name="description" required rows="5" maxlength="5000"
                          class="w-full border border-slate-200 px-3 py-2.5 text-sm focus:outline-none focus:border-orange-accent transition-colors resize-none"
                          placeholder="Please describe your issue in detail..."></textarea>
            </div>
            <div class="flex justify-end gap-3 pt-1">
                <button type="button"
                        onclick="document.getElementById('new-ticket-modal').classList.add('hidden')"
                        class="px-5 py-2.5 text-[12px] font-bold uppercase tracking-wider border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">
                    Cancel
                </button>
                <button type="submit" id="ticket-submit-btn"
                        class="px-5 py-2.5 text-[12px] font-bold uppercase tracking-wider bg-orange-accent text-white hover:opacity-90 transition-opacity">
                    Submit Ticket
                </button>
            </div>
        </form>
    </div>
</div>

<script>
document.getElementById('new-ticket-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form    = this;
    const btn     = document.getElementById('ticket-submit-btn');
    const errBox  = document.getElementById('ticket-form-error');

    btn.disabled    = true;
    btn.textContent = 'Submitting…';
    errBox.classList.add('hidden');

    const token = form.querySelector('input[name="__RequestVerificationToken"]').value;
    const body  = new URLSearchParams(new FormData(form));

    try {
        const res  = await fetch('/support/tickets/create', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token },
            body
        });
        const data = await res.json();
        if (data.success) {
            window.location = '/support/tickets/' + data.ticketId;
        } else {
            errBox.textContent = data.error || 'Failed to submit ticket.';
            errBox.classList.remove('hidden');
            btn.disabled    = false;
            btn.textContent = 'Submit Ticket';
        }
    } catch {
        errBox.textContent = 'An unexpected error occurred. Please try again.';
        errBox.classList.remove('hidden');
        btn.disabled    = false;
        btn.textContent = 'Submit Ticket';
    }
});
</script>
