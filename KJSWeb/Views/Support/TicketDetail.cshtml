@model KJSWeb.Models.SupportTicket
@using KJSWeb.Models
@{
    ViewData["Title"] = "Ticket: " + Model.Title;
    var messages = ViewBag.Messages as List<TicketMessage> ?? new List<TicketMessage>();

    string StatusBadgeClass(TicketStatus status) => status switch
    {
        TicketStatus.Open       => "bg-yellow-100 text-yellow-800",
        TicketStatus.InProgress => "bg-blue-100 text-blue-800",
        TicketStatus.Resolved   => "bg-green-100 text-green-800",
        _                       => "bg-slate-100 text-slate-600"
    };

    string StatusLabel(TicketStatus status) => status switch
    {
        TicketStatus.Open       => "Open",
        TicketStatus.InProgress => "In Progress",
        TicketStatus.Resolved   => "Resolved",
        _                       => status.ToString()
    };

    bool canReply = Model.Status != TicketStatus.Resolved;
}

<div class="max-w-3xl mx-auto">

    <!-- Back link -->
    <a href="/support/tickets"
       class="inline-flex items-center gap-1.5 text-[11px] font-black uppercase tracking-widest text-slate-400 hover:text-orange-accent transition-colors mb-8">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        All Tickets
    </a>

    <!-- Ticket Header -->
    <div class="bg-white dark:bg-gray-800 border border-slate-200 dark:border-gray-700 rounded-sm p-6 mb-6">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
            <div class="flex-1 min-w-0">
                <h1 class="text-xl font-bold text-slate-800 dark:text-gray-100 leading-snug mb-2">@Model.Title</h1>
                <div class="flex flex-wrap items-center gap-3 text-[11px] text-slate-400 dark:text-gray-500 font-bold uppercase tracking-wider">
                    <span class="font-mono normal-case font-normal text-slate-300 dark:text-gray-600">
                        #@Model.Id.Substring(0, Math.Min(8, Model.Id.Length))
                    </span>
                    <span>·</span>
                    <span>Opened @Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    @if (Model.LastReplyAt.HasValue)
                    {
                        <span>·</span>
                        <span>Last reply @Model.LastReplyAt.Value.ToString("MMM dd, yyyy")</span>
                    }
                </div>
            </div>
            <div class="shrink-0">
                <span class="inline-block px-3 py-1.5 rounded text-[10px] font-bold uppercase tracking-wider @StatusBadgeClass(Model.Status)">
                    @StatusLabel(Model.Status)
                </span>
            </div>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-5 p-4 bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 text-red-700 dark:text-red-400 text-sm font-medium">
            @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="mb-5 p-4 bg-green-50 dark:bg-green-900/20 border-l-4 border-green-500 text-green-700 dark:text-green-400 text-sm font-medium">
            @TempData["Success"]
        </div>
    }

    <!-- Conversation Thread -->
    <div class="space-y-4 mb-6">
        @if (!messages.Any())
        {
            <div class="text-center py-10 bg-white dark:bg-gray-800 border border-slate-200 dark:border-gray-700 rounded-sm">
                <p class="text-slate-400 dark:text-gray-500 text-sm font-semibold">No messages yet.</p>
                @if (canReply)
                {
                    <p class="text-slate-400 dark:text-gray-500 text-xs mt-1">Use the form below to add your first message.</p>
                }
            </div>
        }
        else
        {
            @foreach (var msg in messages)
            {
                if (msg.IsAdmin)
                {
                    <!-- Admin message -->
                    <div class="flex gap-3">
                        <div class="shrink-0 w-8 h-8 rounded-full bg-orange-accent flex items-center justify-center text-white text-[11px] font-black mt-1">
                            S
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 rounded-sm px-4 py-3">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-[10px] font-black uppercase tracking-widest text-orange-accent">Support Team</span>
                                    <span class="text-[10px] text-slate-400 dark:text-gray-500">@msg.CreatedAt.ToString("MMM dd, yyyy 'at' h:mm tt")</span>
                                </div>
                                <p class="text-sm text-slate-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap break-words">@msg.Message</p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- User message -->
                    <div class="flex gap-3 justify-end">
                        <div class="flex-1 min-w-0 flex flex-col items-end">
                            <div class="bg-white dark:bg-gray-800 border border-slate-200 dark:border-gray-700 rounded-sm px-4 py-3 max-w-prose w-full">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-[10px] font-black uppercase tracking-widest text-slate-600 dark:text-gray-400">You</span>
                                    <span class="text-[10px] text-slate-400 dark:text-gray-500">@msg.CreatedAt.ToString("MMM dd, yyyy 'at' h:mm tt")</span>
                                </div>
                                <p class="text-sm text-slate-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap break-words">@msg.Message</p>
                            </div>
                        </div>
                        <div class="shrink-0 w-8 h-8 rounded-full bg-slate-200 dark:bg-gray-700 flex items-center justify-center text-slate-500 dark:text-gray-400 text-[11px] font-black mt-1">
                            U
                        </div>
                    </div>
                }
            }
        }
    </div>

    <!-- Reply Form (only for open/in-progress tickets) -->
    @if (canReply)
    {
        <div class="bg-white dark:bg-gray-800 border border-slate-200 dark:border-gray-700 rounded-sm p-6">
            <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-500 dark:text-gray-400 mb-4">Reply</h3>
            <form method="post" action="/support/tickets/@Model.Id/reply">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <textarea name="message" rows="4" required maxlength="5000"
                              class="w-full border border-slate-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 px-3 py-2.5 text-sm focus:outline-none focus:border-orange-accent transition-colors resize-none"
                              placeholder="Write your reply…"></textarea>
                </div>
                <div class="flex justify-end">
                    <button type="submit"
                            class="inline-flex items-center gap-2 bg-orange-accent text-white px-6 py-2.5 text-[12px] font-bold uppercase tracking-wider hover:opacity-90 transition-opacity">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
                        </svg>
                        Send Reply
                    </button>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="bg-slate-50 dark:bg-gray-700 border border-slate-200 dark:border-gray-600 rounded-sm p-5 text-center">
            <p class="text-sm text-slate-500 dark:text-gray-400 font-medium">
                This ticket is resolved and closed for new replies.
            </p>
        </div>
    }

</div>
