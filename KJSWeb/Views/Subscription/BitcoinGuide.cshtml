@{
    ViewData["Title"] = "How to Pay with Bitcoin";
}

<div class="max-w-3xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-orange-accent mb-6">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.944 17.97L4.58 13.62 11.943 24l7.37-10.38-7.372 4.35h.003zM12.056 0L4.69 12.223l7.365 4.354 7.365-4.35L12.056 0z"/>
            </svg>
        </div>
        <h1 class="text-3xl font-black tracking-tight mb-3 dark:text-gray-100">How to Pay with Bitcoin</h1>
        <p class="text-slate-500 dark:text-gray-400 text-sm max-w-lg mx-auto">
            No account needed on our end — just send Bitcoin directly to the address shown on your payment page. Follow the steps below for your region.
        </p>
    </div>

    <!-- Tab Nav -->
    <div class="flex border-b border-slate-200 dark:border-gray-700 mb-10 overflow-x-auto">
        <button onclick="showTab('all')" id="tab-all"
                class="tab-btn px-5 py-3 text-[11px] font-black uppercase tracking-widest border-b-2 border-orange-accent text-orange-accent whitespace-nowrap">
            Overview
        </button>
        <button onclick="showTab('asia')" id="tab-asia"
                class="tab-btn px-5 py-3 text-[11px] font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 dark:text-gray-500 hover:text-slate-700 dark:hover:text-gray-300 transition-colors whitespace-nowrap">
            🌏 Asia
        </button>
        <button onclick="showTab('europe')" id="tab-europe"
                class="tab-btn px-5 py-3 text-[11px] font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 dark:text-gray-500 hover:text-slate-700 dark:hover:text-gray-300 transition-colors whitespace-nowrap">
            🌍 Europe
        </button>
        <button onclick="showTab('americas')" id="tab-americas"
                class="tab-btn px-5 py-3 text-[11px] font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 dark:text-gray-500 hover:text-slate-700 dark:hover:text-gray-300 transition-colors whitespace-nowrap">
            🌎 Americas
        </button>
    </div>

    <!-- ── OVERVIEW TAB ── -->
    <div id="panel-all">

        <!-- Step by step -->
        <h2 class="text-lg font-black uppercase tracking-tight mb-6 dark:text-gray-100">How It Works — 3 Simple Steps</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 text-center shadow-sm">
                <div class="text-3xl font-black text-orange-accent mb-3">1</div>
                <h3 class="font-black uppercase text-[11px] tracking-widest mb-2 dark:text-gray-100">Get Bitcoin</h3>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed">Buy BTC from an exchange or app in your country. Takes 5–15 minutes to set up.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 text-center shadow-sm">
                <div class="text-3xl font-black text-orange-accent mb-3">2</div>
                <h3 class="font-black uppercase text-[11px] tracking-widest mb-2 dark:text-gray-100">Choose a Plan</h3>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed">Pick Monthly, 3-Month, or Yearly on our <a asp-controller="Subscription" asp-action="Pricing" class="text-orange-accent underline">Pricing page</a> and click Pay with Bitcoin.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 text-center shadow-sm">
                <div class="text-3xl font-black text-orange-accent mb-3">3</div>
                <h3 class="font-black uppercase text-[11px] tracking-widest mb-2 dark:text-gray-100">Send & Wait</h3>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed">Copy our BTC address, send the exact amount, and your access unlocks automatically within minutes.</p>
            </div>
        </div>

        <!-- Recommended Wallets -->
        <h2 class="text-lg font-black uppercase tracking-tight mb-6 dark:text-gray-100">Recommended Wallets</h2>
        <div class="space-y-3 mb-12">
            @{
                var wallets = new[]
                {
                    ("Muun", "iOS + Android", "Best for beginners. Self-custodial, no sign-up required.", "https://muun.com"),
                    ("BlueWallet", "iOS + Android", "Great privacy, open source. Recommended for intermediate users.", "https://bluewallet.io"),
                    ("Trust Wallet", "iOS + Android", "Popular in Asia. Supports many coins including Bitcoin.", "https://trustwallet.com"),
                    ("Coinbase Wallet", "iOS + Android", "Beginner-friendly. Popular in the Americas. Separate from Coinbase exchange.", "https://wallet.coinbase.com"),
                    ("Electrum", "Windows / Mac / Linux", "Best desktop wallet for advanced users.", "https://electrum.org"),
                };
            }
            @foreach (var (name, platform, desc, url) in wallets)
            {
                <div class="flex items-start gap-4 bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-4 shadow-sm">
                    <div class="w-8 h-8 rounded-full bg-orange-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-4 h-4 text-orange-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3" />
                        </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 flex-wrap">
                            <span class="font-black text-sm dark:text-gray-100">@name</span>
                            <span class="text-[9px] font-bold uppercase tracking-widest bg-slate-100 dark:bg-gray-700 text-slate-500 dark:text-gray-400 px-2 py-0.5">@platform</span>
                        </div>
                        <p class="text-slate-500 dark:text-gray-400 text-xs mt-1">@desc</p>
                    </div>
                    <a href="@url" target="_blank" rel="noopener noreferrer"
                       class="text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity shrink-0">
                        Visit →
                    </a>
                </div>
            }
        </div>

        <!-- Paying on our site -->
        <h2 class="text-lg font-black uppercase tracking-tight mb-6 dark:text-gray-100">Paying on SCANDAL69 — Step by Step</h2>
        <ol class="space-y-4 mb-12">
            @{
                var steps = new[]
                {
                    ("Go to Pricing", "Visit the Pricing page and choose Monthly, 3-Month, or Yearly. Click \"Pay with Bitcoin\"."),
                    ("Copy the BTC Address", "You'll see a unique Bitcoin address and a QR code. Copy the address or scan the QR code with your wallet app."),
                    ("Send the Exact Amount", "In your wallet, paste the address and enter the exact BTC amount shown. Do NOT round up or down — send the exact figure."),
                    ("Wait for Confirmation", "Bitcoin transactions typically confirm in 5–30 minutes depending on network traffic. Keep the payment page open — it checks automatically every 10 seconds."),
                    ("Access Unlocks", "Once confirmed, your subscription activates instantly. You'll be redirected to your account page."),
                };
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var (title, detail) = steps[i];
                <li class="flex gap-4 bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-4 shadow-sm">
                    <div class="w-7 h-7 rounded-full bg-orange-accent text-white text-[11px] font-black flex items-center justify-center shrink-0 mt-0.5">@(i+1)</div>
                    <div>
                        <p class="font-black text-sm dark:text-gray-100 mb-1">@title</p>
                        <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed">@detail</p>
                    </div>
                </li>
            }
        </ol>

        <!-- FAQ -->
        <h2 class="text-lg font-black uppercase tracking-tight mb-6 dark:text-gray-100">Common Questions</h2>
        <div class="space-y-3 mb-12">
            @{
                var faqs = new[]
                {
                    ("Why only Bitcoin?", "Bitcoin gives you complete privacy — no credit card data stored, no identity required on our end. Payments are direct wallet-to-wallet with no middleman."),
                    ("Can I send from a Binance/Coinbase exchange wallet?", "Yes, but we recommend withdrawing to your own wallet first. Exchange withdrawals can be delayed by hours and sometimes require identity verification for transfers."),
                    ("What if I send the wrong amount?", "If you send less, the payment won't activate. If you send more, the excess is non-refundable as Bitcoin transactions are irreversible. Always send the exact amount shown."),
                    ("How long does confirmation take?", "Usually 5–30 minutes. During high network traffic it can take up to a few hours. The page polls automatically — no need to refresh."),
                    ("Is my subscription anonymous?", "Yes. We only store your email address (used for login) and your BTC transaction ID. No personal data, no KYC."),
                };
            }
            @foreach (var (q, a) in faqs)
            {
                <details class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 shadow-sm group">
                    <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                        <span class="font-black text-sm dark:text-gray-100">@q</span>
                        <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </summary>
                    <p class="px-5 pb-4 text-slate-500 dark:text-gray-400 text-xs leading-relaxed">@a</p>
                </details>
            }
        </div>
    </div>

    <!-- ── ASIA TAB ── -->
    <div id="panel-asia" class="hidden">
        <h2 class="text-lg font-black uppercase tracking-tight mb-2 dark:text-gray-100">🌏 Buying Bitcoin in Asia</h2>
        <p class="text-slate-500 dark:text-gray-400 text-sm mb-8">Choose the exchange or method that works in your country.</p>

        <div class="space-y-6 mb-10">

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Binance</h3>
                    <div class="flex gap-2 flex-wrap">
                        <span class="text-[9px] font-bold uppercase bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 tracking-widest">Japan · Korea · Thailand · Philippines · Indonesia</span>
                    </div>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Largest exchange in Asia. Supports local bank transfers, credit/debit cards, and P2P trading. Available in most Asian countries.</p>
                <ol class="text-xs text-slate-600 dark:text-gray-400 space-y-1 list-decimal list-inside mb-4">
                    <li>Sign up at binance.com and complete identity verification</li>
                    <li>Deposit local currency via bank transfer or card</li>
                    <li>Buy Bitcoin (BTC) in the spot market</li>
                    <li>Withdraw BTC to your wallet address (our payment address)</li>
                </ol>
                <a href="https://www.binance.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Binance →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">OKX</h3>
                    <span class="text-[9px] font-bold uppercase bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 px-2 py-0.5 tracking-widest">Most of Asia</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Popular in Southeast Asia and China. Supports P2P trading with local payment methods including Alipay, WeChat Pay, and bank transfers.</p>
                <a href="https://www.okx.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit OKX →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Bybit</h3>
                    <span class="text-[9px] font-bold uppercase bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 px-2 py-0.5 tracking-widest">Southeast Asia · Middle East</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Strong P2P marketplace with many local payment methods. Good option for Thailand, Vietnam, Malaysia, and the Middle East.</p>
                <a href="https://www.bybit.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Bybit →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Paxful (P2P)</h3>
                    <span class="text-[9px] font-bold uppercase bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 px-2 py-0.5 tracking-widest">All countries · No KYC options</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Peer-to-peer marketplace. Buy directly from other users using local bank transfers, mobile money, gift cards, and more. Some sellers require no ID.</p>
                <a href="https://paxful.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Paxful →
                </a>
            </div>

        </div>

        <div class="bg-orange-accent/5 border border-orange-accent/20 p-5 text-xs text-slate-600 dark:text-gray-400 leading-relaxed">
            <strong class="text-orange-accent font-black uppercase tracking-widest text-[10px]">💡 Tip for Asia:</strong><br/>
            In Japan and Thailand, convenience stores (7-Eleven, FamilyMart) sometimes offer Bitcoin top-up services via local crypto apps. Check your country's app store for local crypto wallet options.
        </div>
    </div>

    <!-- ── EUROPE TAB ── -->
    <div id="panel-europe" class="hidden">
        <h2 class="text-lg font-black uppercase tracking-tight mb-2 dark:text-gray-100">🌍 Buying Bitcoin in Europe</h2>
        <p class="text-slate-500 dark:text-gray-400 text-sm mb-8">Europe has some of the most regulated and easy-to-use Bitcoin exchanges.</p>

        <div class="space-y-6 mb-10">

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Kraken</h3>
                    <span class="text-[9px] font-bold uppercase bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 tracking-widest">All EU/EEA countries</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">One of the most trusted exchanges in Europe. Supports SEPA bank transfers (free, 1–2 days) and debit cards. Licensed in multiple EU countries.</p>
                <ol class="text-xs text-slate-600 dark:text-gray-400 space-y-1 list-decimal list-inside mb-4">
                    <li>Sign up at kraken.com</li>
                    <li>Verify identity (passport or ID card)</li>
                    <li>Deposit EUR via SEPA transfer from your bank</li>
                    <li>Buy BTC in the exchange</li>
                    <li>Withdraw to your wallet or directly to our payment address</li>
                </ol>
                <a href="https://www.kraken.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Kraken →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Bitstamp</h3>
                    <span class="text-[9px] font-bold uppercase bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 tracking-widest">EU · UK</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Europe's oldest exchange (est. 2011). Based in Luxembourg. Supports SEPA transfers, credit cards, and GBP for UK users. Very reliable.</p>
                <a href="https://www.bitstamp.net" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Bitstamp →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Revolut</h3>
                    <span class="text-[9px] font-bold uppercase bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 px-2 py-0.5 tracking-widest">UK · EU (30+ countries)</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">If you already use Revolut, you can buy Bitcoin directly in the app. Note: Revolut holds the Bitcoin in custody — to send it to us, you must first withdraw to an external wallet.</p>
                <a href="https://www.revolut.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Revolut →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Relai (No KYC)</h3>
                    <span class="text-[9px] font-bold uppercase bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 px-2 py-0.5 tracking-widest">Switzerland · EU · UK</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Bitcoin-only app from Switzerland. Buy up to €900/day with no KYC required. Sends directly to your own wallet — ideal for privacy.</p>
                <a href="https://relai.app" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Relai →
                </a>
            </div>

        </div>

        <div class="bg-orange-accent/5 border border-orange-accent/20 p-5 text-xs text-slate-600 dark:text-gray-400 leading-relaxed">
            <strong class="text-orange-accent font-black uppercase tracking-widest text-[10px]">💡 Tip for Europe:</strong><br/>
            SEPA transfers are free and available in all EU/EEA countries. Use Kraken or Bitstamp for the cheapest route — deposit EUR via bank transfer, buy BTC, then withdraw directly to our payment address.
        </div>
    </div>

    <!-- ── AMERICAS TAB ── -->
    <div id="panel-americas" class="hidden">
        <h2 class="text-lg font-black uppercase tracking-tight mb-2 dark:text-gray-100">🌎 Buying Bitcoin in the Americas</h2>
        <p class="text-slate-500 dark:text-gray-400 text-sm mb-8">Options for the US, Canada, Mexico, and Latin America.</p>

        <div class="space-y-6 mb-10">

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Cash App</h3>
                    <span class="text-[9px] font-bold uppercase bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 tracking-widest">USA only</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">The easiest way to buy Bitcoin in the US. Link your bank or debit card, buy BTC, and withdraw directly to any Bitcoin address. Fast and beginner-friendly.</p>
                <ol class="text-xs text-slate-600 dark:text-gray-400 space-y-1 list-decimal list-inside mb-4">
                    <li>Download Cash App on iOS or Android</li>
                    <li>Link your bank account or debit card</li>
                    <li>Tap the Bitcoin tab and buy BTC</li>
                    <li>Tap "Withdraw Bitcoin" and paste our payment address</li>
                </ol>
                <a href="https://cash.app" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Cash App →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Coinbase</h3>
                    <span class="text-[9px] font-bold uppercase bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 tracking-widest">USA · Canada · Most of Americas</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Most popular US exchange. Easy to use, regulated, and widely trusted. Buy BTC with bank transfer or debit card, then send to our payment address.</p>
                <a href="https://www.coinbase.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Coinbase →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Kraken</h3>
                    <span class="text-[9px] font-bold uppercase bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 tracking-widest">USA · Canada</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Lower fees than Coinbase. Supports ACH bank transfers (US) and wire transfers. Good for buying larger amounts.</p>
                <a href="https://www.kraken.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Kraken →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Bitso</h3>
                    <span class="text-[9px] font-bold uppercase bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 px-2 py-0.5 tracking-widest">Mexico · Brazil · Argentina</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">Leading Latin American exchange. Buy BTC with MXN, BRL, or ARS via local bank transfer (SPEI in Mexico, PIX in Brazil). No international card needed.</p>
                <a href="https://bitso.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Bitso →
                </a>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-slate-100 dark:border-gray-700 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                    <h3 class="font-black uppercase tracking-widest text-[12px] dark:text-gray-100">Paxful (P2P)</h3>
                    <span class="text-[9px] font-bold uppercase bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 px-2 py-0.5 tracking-widest">All countries · No KYC options</span>
                </div>
                <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-3">P2P marketplace available everywhere. Pay with Zelle, PayPal, gift cards, or local bank transfer. Some sellers require no ID verification.</p>
                <a href="https://paxful.com" target="_blank" rel="noopener noreferrer"
                   class="inline-block text-[10px] font-black uppercase tracking-widest text-orange-accent hover:opacity-70 transition-opacity">
                    Visit Paxful →
                </a>
            </div>

        </div>

        <div class="bg-orange-accent/5 border border-orange-accent/20 p-5 text-xs text-slate-600 dark:text-gray-400 leading-relaxed">
            <strong class="text-orange-accent font-black uppercase tracking-widest text-[10px]">💡 Tip for the Americas:</strong><br/>
            US users: Cash App is the fastest route — buy BTC and withdraw to our address in under 10 minutes. Latin American users: Bitso supports local payment methods so you don't need a credit card.
        </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center bg-black dark:bg-gray-800 text-white p-8">
        <p class="text-slate-400 text-xs uppercase tracking-widest mb-4">Ready to subscribe?</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a asp-controller="Subscription" asp-action="Pricing"
               class="inline-block bg-orange-accent text-white px-8 py-3 text-[13px] font-black uppercase tracking-widest hover:opacity-90 transition-opacity">
                View Plans →
            </a>
            <a href="https://scandal69.com/Subscription/Payment"
               class="inline-block border border-white/20 text-white px-8 py-3 text-[13px] font-black uppercase tracking-widest hover:bg-white/5 transition-colors">
                Go to Payment →
            </a>
        </div>
    </div>

</div>

@section Scripts {
<script>
    function showTab(name) {
        ['all', 'asia', 'europe', 'americas'].forEach(function(t) {
            document.getElementById('panel-' + t).classList.add('hidden');
            var btn = document.getElementById('tab-' + t);
            btn.classList.remove('border-orange-accent', 'text-orange-accent');
            btn.classList.add('border-transparent', 'text-slate-400');
        });
        document.getElementById('panel-' + name).classList.remove('hidden');
        var active = document.getElementById('tab-' + name);
        active.classList.add('border-orange-accent', 'text-orange-accent');
        active.classList.remove('border-transparent', 'text-slate-400');
    }
</script>
}
