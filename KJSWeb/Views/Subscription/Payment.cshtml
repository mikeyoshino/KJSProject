@model KJSWeb.Models.Subscription
@{
    ViewData["Title"] = "Payment";
    var btcPrice = (decimal)(ViewBag.BtcPrice ?? 0m);
    var userId = User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<div class="max-w-lg mx-auto">
    <div class="bg-black text-white p-6 sm:p-10 shadow-2xl text-center">
        <h1 class="text-2xl font-black tracking-tight mb-2">@Localizer["Pay with Bitcoin"]</h1>
        <p class="text-slate-400 text-[11px] uppercase tracking-widest mb-8">
            @(KJSWeb.Models.SubscriptionPlans.All.ContainsKey(Model.Plan)
                ? KJSWeb.Models.SubscriptionPlans.All[Model.Plan].Label
                : Model.Plan) Plan — $@Model.AmountUsd.ToString("0.00")
        </p>

        <!-- Status Badge -->
        <div id="statusBadge" class="mb-6">
            @if (Model.Status == "pending")
            {
                <span class="inline-block bg-yellow-500/20 text-yellow-400 text-[11px] font-bold uppercase tracking-widest px-4 py-2">
                    ⏳ Awaiting Payment
                </span>
            }
            else if (Model.Status == "confirming")
            {
                <span class="inline-block bg-blue-500/20 text-blue-400 text-[11px] font-bold uppercase tracking-widest px-4 py-2">
                    🔄 Confirming Transaction...
                </span>
            }
            else if (Model.Status == "active")
            {
                <span class="inline-block bg-green-500/20 text-green-400 text-[11px] font-bold uppercase tracking-widest px-4 py-2">
                    ✓ Payment Confirmed!
                </span>
            }
        </div>

        <!-- QR Code -->
        <div class="mb-6">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=bitcoin:@Model.BtcAddress?amount=@Model.AmountBtc?.ToString("0.00000000")"
                 alt="Bitcoin QR Code"
                 class="mx-auto bg-white p-3"
                 id="qrCode" />
        </div>

        <!-- BTC Amount -->
        <div class="bg-[#121212] border border-white/10 p-5 mb-4">
            <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-2">@Localizer["Send exactly"]</p>
            <p class="text-2xl font-black text-orange-accent" id="btcAmount">
                ₿ @Model.AmountBtc?.ToString("0.00000000")
            </p>
            <p class="text-slate-500 text-xs mt-1">≈ $@Model.AmountUsd.ToString("0.00") USD</p>
        </div>

        <!-- BTC Address -->
        <div class="bg-[#121212] border border-white/10 p-5 mb-6">
            <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-3">@Localizer["To this address"]</p>
            <p class="text-white font-mono text-sm break-all text-center mb-3" id="btcAddress">@Model.BtcAddress</p>
            <button onclick="copyAddress()" id="copyBtn"
                    class="w-full bg-orange-accent text-white text-[10px] font-bold uppercase px-3 py-2 hover:opacity-80 transition-opacity">
                @Localizer["Copy address"]
            </button>
        </div>

        <p class="text-slate-500 text-[10px] uppercase tracking-wider">
            Payment will be detected automatically. Do not close this page.
        </p>
        <a asp-controller="Subscription" asp-action="BitcoinGuide"
           class="inline-block mt-4 text-slate-400 hover:text-orange-accent text-[10px] font-bold uppercase tracking-widest transition-colors">
            Need help? View Bitcoin payment guide →
        </a>
    </div>
</div>

@if (isAuthenticated)
{
    <!-- Floating Support Button -->
    <button onclick="document.getElementById('support-modal').classList.remove('hidden')"
            class="fixed bottom-5 right-5 w-14 h-14 bg-orange-accent text-white rounded-full shadow-2xl flex items-center justify-center hover:opacity-90 transition-opacity z-30"
            title="Contact support">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
    </button>

    <!-- Support Modal -->
    <div id="support-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-md p-6">
            <h3 class="text-lg font-black text-slate-900 dark:text-gray-100 mb-1">Contact Support</h3>
            <p class="text-slate-400 dark:text-gray-500 text-sm mb-5">Tell us how we can help with your payment.</p>
            <form id="support-form" class="space-y-4">
                @Html.AntiForgeryToken()

                <div>
                    <label class="block text-xs font-bold text-slate-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Subject</label>
                    <input type="text" name="title" placeholder="e.g. Payment issue, missing download"
                           required
                           class="w-full border border-slate-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent" />
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Category</label>
                    <select name="category"
                            class="w-full border border-slate-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent">
                        <option value="payment">Payment Issue</option>
                        <option value="download">Download Issue</option>
                        <option value="account">Account Issue</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 dark:text-gray-400 mb-1.5 uppercase tracking-wider">Description</label>
                    <textarea name="description" rows="4" placeholder="Please describe your issue in detail..."
                              required
                              class="w-full border border-slate-200 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-accent resize-none"></textarea>
                </div>

                <div id="support-message" class="hidden p-3 rounded-lg text-sm"></div>

                <div class="flex gap-3">
                    <button type="submit" class="flex-1 bg-orange-accent text-white py-2.5 text-sm font-bold rounded-lg hover:opacity-90 transition-opacity">
                        Send Ticket
                    </button>
                    <button type="button" onclick="document.getElementById('support-modal').classList.add('hidden')"
                            class="flex-1 bg-slate-100 dark:bg-gray-700 text-slate-700 dark:text-gray-300 py-2.5 text-sm font-bold rounded-lg hover:bg-slate-200 dark:hover:bg-gray-600 transition-colors">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
    function copyAddress() {
        var addr = document.getElementById('btcAddress').textContent.trim();
        navigator.clipboard.writeText(addr).then(function() {
            var btn = document.getElementById('copyBtn');
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = 'Copy Address'; }, 2000);
        });
    }

    // Handle support form submission
    @if (isAuthenticated)
    {
    <text>
    document.getElementById('support-form').addEventListener('submit', function(e) {
        e.preventDefault();

        var form = this;
        var formData = new FormData(form);

        fetch('/support/tickets/create', {
            method: 'POST',
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var messageEl = document.getElementById('support-message');
            if (data.success) {
                messageEl.classList.remove('hidden', 'bg-red-50', 'text-red-600');
                messageEl.classList.add('bg-green-50', 'text-green-700');
                messageEl.textContent = 'Ticket created successfully! We\'ll be in touch soon.';
                form.reset();
                setTimeout(function() {
                    document.getElementById('support-modal').classList.add('hidden');
                    messageEl.classList.add('hidden');
                }, 2000);
            } else {
                messageEl.classList.remove('hidden', 'bg-green-50', 'text-green-700');
                messageEl.classList.add('bg-red-50', 'text-red-600');
                messageEl.textContent = data.error || 'Failed to create ticket. Please try again.';
            }
        })
        .catch(function(err) {
            var messageEl = document.getElementById('support-message');
            messageEl.classList.remove('hidden', 'bg-green-50', 'text-green-700');
            messageEl.classList.add('bg-red-50', 'text-red-600');
            messageEl.textContent = 'An error occurred. Please try again.';
        });
    });
    </text>
    }

    // Poll for payment status every 10 seconds
    var address = '@Model.BtcAddress';
    var pollInterval = setInterval(function() {
        fetch('/api/subscription/status/' + address)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var badge = document.getElementById('statusBadge');
                if (data.status === 'confirming') {
                    badge.innerHTML = '<span class="inline-block bg-blue-500/20 text-blue-400 text-[11px] font-bold uppercase tracking-widest px-4 py-2">🔄 Confirming Transaction...</span>';
                } else if (data.status === 'active') {
                    badge.innerHTML = '<span class="inline-block bg-green-500/20 text-green-400 text-[11px] font-bold uppercase tracking-widest px-4 py-2">✓ Payment Confirmed!</span>';
                    clearInterval(pollInterval);
                    // Redirect after 3 seconds
                    setTimeout(function() {
                        window.location.href = '/Subscription/MySubscription';
                    }, 3000);
                }
            })
            .catch(function() {});
    }, 10000);
</script>
}
