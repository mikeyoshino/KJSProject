@model KJSWeb.Models.Post
@{
    ViewData["Title"] = Model.Title;
    var recentPosts = ViewBag.RecentPosts as List<KJSWeb.Models.Post> ?? new List<KJSWeb.Models.Post>();
    var siteName = "Asian Scandal";
    var siteUrl = Context.Request.Scheme + "://" + Context.Request.Host;
}

<div class="flex flex-col md:flex-row gap-10">
    <!-- Main Content -->
    <div class="flex-1 min-w-0">
        <article>
            <header class="mb-8">
                @if (Model.Categories != null && Model.Categories.Any())
                {
                    <div class="flex flex-wrap gap-2 mb-4">
                        @foreach (var cat in Model.Categories)
                        {
                            <span class="bg-orange-accent text-white text-[9px] font-black uppercase px-2 py-1 tracking-widest cursor-default">@cat</span>
                        }
                    </div>
                }
                <h1 class="text-4xl font-black leading-tight mb-3 tracking-tighter uppercase italic">@Model.Title</h1>
                <div class="flex items-center gap-4 flex-wrap">
                    <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest">@Localizer["Added:"] @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    <span class="text-orange-accent text-[9px] font-black uppercase tracking-widest border border-orange-accent/30 px-2 py-0.5 rounded-sm">@Localizer["Original"]</span>
                    <span class="flex items-center gap-1 text-slate-400 text-[10px] font-bold uppercase tracking-widest">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        @Model.ViewCount.ToString("N0")
                    </span>
                </div>
            </header>

            <div class="prose max-w-none overflow-x-hidden [&_img]:max-w-full [&_img]:h-auto [&_img]:block [&_img]:my-5 [&_img]:rounded-sm">
                @{
                    var workerBase = (string)(ViewBag.WorkerBaseUrl ?? "");
                    var b2DirectBase = (string)(ViewBag.B2DirectBase ?? "");
                    var content = Model.ContentHtml
                        .Replace("{{SiteName}}", siteName)
                        .Replace("{{SiteUrl}}", siteUrl);

                    // Rewrite hardcoded B2 direct URLs to go through the Cloudflare Worker (legacy full URLs)
                    if (!string.IsNullOrEmpty(workerBase) && !string.IsNullOrEmpty(b2DirectBase))
                        content = content.Replace(b2DirectBase, workerBase);

                    // Rewrite relative B2 paths (e.g. src="posts/{id}/images/1.jpg") to full worker URLs
                    if (!string.IsNullOrEmpty(workerBase))
                        content = System.Text.RegularExpressions.Regex.Replace(
                            content,
                            @"(src=[""'])(?!https?://)(posts/)",
                            $"$1{workerBase}/$2");
                }
                @Html.Raw(content)
            </div>

            <!-- Download Section — only shown when files are available on our servers -->
            @if (Model.OurDownloadLink != null && Model.OurDownloadLink.Any())
            {
                @await Html.PartialAsync("_PremiumDownload", new KJSWeb.Models.DownloadComponentModel
                {
                    DownloadCount = Model.OurDownloadLink.Count,
                    DownloadUrls = ViewBag.DownloadUrls as List<string> ?? new List<string>(),
                    IsSubscribed = ViewBag.HasActiveSubscription == true
                })
            }

            <!-- Tags Cloud -->
            @if (Model.Tags != null && Model.Tags.Any())
            {
                <div class="mt-12 border-t border-slate-100 dark:border-gray-700 pt-8">
                    <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 dark:text-gray-500 mb-4">@Localizer["Metadata Tags"]</h3>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="bg-slate-50 dark:bg-gray-700 text-slate-500 dark:text-gray-400 hover:bg-orange-accent hover:text-white px-3 py-1.5 rounded-sm text-[10px] font-bold uppercase tracking-wider transition-colors cursor-default">#@tag</span>
                        }
                    </div>
                </div>
            }

            <!-- Related Posts -->
            @await Html.PartialAsync("_RelatedPostsGrid", ViewBag.RelatedPosts as List<KJSWeb.Models.Post> ?? new List<KJSWeb.Models.Post>())
        </article>
    </div>

    <!-- Sidebar (Same as home for consistency) -->
    <aside class="w-full md:w-64 lg:w-80 shrink-0">
        @if (recentPosts != null && recentPosts.Any())
        {
            <div class="mb-10">
                <h4 class="text-sm font-bold uppercase tracking-wider border-b-2 border-black dark:border-gray-600 pb-2 mb-5">@Localizer["More from Network"]</h4>
                <div class="space-y-5">
                    @foreach (var post in recentPosts)
                    {
                        <div class="flex gap-4">
                            @{ var sideCtrl = post.SourceNameRaw == "AsianScandal" ? "AsianScandal" : "Home"; }
                            <a asp-controller="@sideCtrl" asp-action="Details" asp-route-id="@post.Id" asp-route-slug="@KJSWeb.Helpers.SeoHelper.ToSlug(post.Title)" class="shrink-0">
                                <img src="@post.ThumbnailUrl" alt="@post.Title" class="w-20 h-14 object-cover rounded-sm" loading="lazy" />
                            </a>
                            <div class="min-w-0">
                                <a asp-controller="@sideCtrl" asp-action="Details" asp-route-id="@post.Id" asp-route-slug="@KJSWeb.Helpers.SeoHelper.ToSlug(post.Title)" class="text-sm font-semibold leading-tight line-clamp-2 hover:text-orange-accent transition-colors block">@post.Title</a>
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-1 block">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </aside>
</div>

@section Schema {
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "BlogPosting",
      "mainEntityOfPage": {
        "@@type": "WebPage",
        "@@id": "@(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"
      },
      "headline": "@Html.Raw(Model.Title.Replace("\"", "\\\""))",
      "image": "@Html.Raw(Model.ThumbnailUrl)",  
      "datePublished": "@Model.CreatedAt.ToString("o")",
      "dateModified": "@Model.CreatedAt.ToString("o")",
      "author": {
        "@@type": "Organization",
        "name": "SCANDAL69"
      },
      "publisher": {
        "@@type": "Organization",
        "name": "SCANDAL69"
      }
    }
    </script>
}

